<Page x:Class="Restaurant.MenuPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restaurant"
      xmlns:imgcon="clr-namespace:Restaurant.Product"
      mc:Ignorable="d" d:DesignWidth="800"
      Title="MenuPage" Foreground="White">

    <Page.Resources>
        <imgcon:ImagePathConverter x:Key="ImagePathConverter"/>

        <Style x:Key="DishCardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E8E0D5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <DropShadowEffect x:Key="CardShadow" 
                          BlurRadius="8" 
                          ShadowDepth="2" 
                          Opacity="0.1" 
                          Direction="270"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" 
                Background="#2C1810" 
                Padding="40,30" 
                Margin="0,0,0,0">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="МЕНЮ" 
                           FontSize="36" 
                           FontWeight="Bold"
                           Foreground="#D4A574"
                           HorizontalAlignment="Center"
                           FontFamily="Georgia"/>
                <TextBlock Text="Ресторана" 
                           FontSize="16"
                           Foreground="#A09080"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0"
                           FontFamily="Georgia"
                           FontStyle="Italic"/>
                <Border Width="100" Height="2" 
                        Background="#D4A574" 
                        Margin="0,15,0,0"
                        HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto" 
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#FAF9F6">
            <ItemsControl ItemsSource="{Binding Categories}"  d:ItemsSource="{d:SampleData ItemCount=6}" 
                          Margin="0,20,0,40">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,30">
                            <Grid Margin="40,10,40,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Height="1" 
                                        Background="#D4A574" 
                                        VerticalAlignment="Center"/>

                                <Border Grid.Column="1" 
                                        Background="#2C1810" 
                                        CornerRadius="20" 
                                        Padding="20,8" 
                                        Margin="15,0">
                                    <TextBlock Text="{Binding CategoryName}" 
                                               FontSize="22" 
                                               FontWeight="Bold"
                                               Foreground="#D4A574"
                                               FontFamily="Georgia"
                                               HorizontalAlignment="Center"/>
                                </Border>

                                <Border Grid.Column="2" Height="1" 
                                        Background="#D4A574" 
                                        VerticalAlignment="Center"/>
                            </Grid>

                            <ItemsControl ItemsSource="{Binding Dishes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" 
                                                   HorizontalAlignment="Center"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource DishCardStyle}"
                                                Width="380"
                                                Margin="10"
                                                Effect="{StaticResource CardShadow}">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="200"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0" 
                                                        CornerRadius="12,12,0,0"
                                                        Background="#F5F0EB"
                                                        ClipToBounds="True">
                                                    <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                                           Stretch="UniformToFill"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                                </Border>

                                                <TextBlock Grid.Row="1" 
                                                           Text="{Binding Name}"
                                                           FontSize="20"
                                                           FontWeight="Bold"
                                                           FontFamily="Georgia"
                                                           Foreground="#2C1810"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           Margin="20,15,20,5"/>

                                                <TextBlock Grid.Row="2" 
                                                           Text="{Binding Ingredients, StringFormat='({0})'}"
                                                           FontSize="13"
                                                           FontFamily="Georgia"
                                                           FontStyle="Italic"
                                                           Foreground="#8A7A6A"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           Margin="20,0,20,0"
                                                           MaxHeight="40"
                                                           TextTrimming="CharacterEllipsis"/>

                                                <Border Grid.Row="3" 
                                                        Background="#2C1810" 
                                                        CornerRadius="0,0,12,12"
                                                        Padding="0,10"
                                                        Margin="0,15,0,0">
                                                    <TextBlock Text="{Binding Price, StringFormat='C'}"
                                                               FontSize="22"
                                                               FontWeight="Bold"
                                                               FontFamily="Century Gothic"
                                                               Foreground="#D4A574"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Margin="0,20,0,0">
            <Button Content="←  Назад"
                    Height="40" Width="110"
                    HorizontalAlignment="Right"
                    Click="Back_Click"
                    Background="White"
                    Foreground="#64748B"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Border>
    </Grid>
</Page>
