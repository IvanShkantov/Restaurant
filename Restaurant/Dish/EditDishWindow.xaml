<Window x:Class="Restaurant.Dish.EditDishWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant.Dish"
        xmlns:imgcon="clr-namespace:Restaurant.Product"
        mc:Ignorable="d"
        Title="Редактирование блюда"
        Background="#F8FAFC"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <imgcon:ImagePathConverter x:Key="ImagePathConverter"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="2" Opacity="0.08"/>
        <DropShadowEffect x:Key="ImageShadow" BlurRadius="15" ShadowDepth="4" Opacity="0.12"/>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="25" Background="White" CornerRadius="16" 
                Margin="0,0,0,18" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" 
                        Width="170" Height="170"
                        Background="#F1F5F9" 
                        CornerRadius="14"
                        Margin="0,0,24,0"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        Effect="{StaticResource ImageShadow}">
                    <Image x:Name="DishImage"
                           Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                           Stretch="Uniform"
                           Margin="8"/>
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Название блюда" FontWeight="SemiBold" 
                               Foreground="#64748B" FontSize="12" Margin="0,0,0,6"/>
                    <TextBox x:Name="NameBox"
                             Text="{Binding DishName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Padding="12,10" 
                             FontWeight="SemiBold"
                             Background="#F8FAFC"
                             BorderBrush="#E2E8F0"
                             BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>

                    <Grid Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,14,0">
                            <TextBlock Text="Цена" FontWeight="SemiBold" 
                                       Foreground="#64748B" FontSize="12" Margin="0,0,0,6"/>
                            <Grid>
                                <TextBox x:Name="PriceBox"
                                         Text="{Binding Price, StringFormat='N2', UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="16" Padding="12,10"
                                         FontWeight="SemiBold"
                                         Background="#F8FAFC"
                                         BorderBrush="#E2E8F0"
                                         BorderThickness="1">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="10"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>
                                <TextBlock Text="$" FontSize="16" Foreground="#94A3B8" 
                                           VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                            </Grid>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Категория" FontWeight="SemiBold" 
                                       Foreground="#64748B" FontSize="12" Margin="0,0,0,6"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CategoryCombo"
                                          ItemsSource="{Binding Categories}"
                                          SelectedItem="{Binding SelectedCategory}"
                                          DisplayMemberPath="CategoryName"
                                          FontSize="14" 
                                          Padding="10,8"
                                          Background="#F8FAFC"
                                          BorderBrush="#E2E8F0"
                                          BorderThickness="1">
                                    <ComboBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="10"/>
                                        </Style>
                                    </ComboBox.Resources>
                                </ComboBox>
                                <Button Grid.Column="1" 
                                        Content="📋" 
                                        Width="40" Height="40"
                                        Margin="8,0,0,0"
                                        Click="CategoriesBtn_Click"
                                        ToolTip="Управление категориями"
                                        Background="#F1F5F9"
                                        BorderThickness="0"
                                        FontSize="16"
                                        Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="10"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Button x:Name="ChooseImageBtn" 
                            Content="📷  Выбрать изображение"
                            Height="38" Width="180"
                            Margin="0,18,0,0"
                            Click="ChooseImageBtn_Click"
                            Background="White"
                            Foreground="#475569"
                            BorderBrush="#CBD5E1"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            FontSize="13"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="0" Background="White" CornerRadius="14" 
                Margin="0,8,0,0" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0" Margin="18,16,18,0">
                    <TextBlock Text="Ингредиенты" FontSize="16" FontWeight="Bold" 
                               Foreground="#1E293B" VerticalAlignment="Center"/>
                    <Button x:Name="AddProductBtn" 
                            Content="+  Добавить продукт"
                            Height="36" Padding="14,0"
                            HorizontalAlignment="Right"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="AddProductBtn_Click"
                            Background="#3B82F6"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            FontSize="13"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="9"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>

                <Border Grid.Row="1" Background="#F8FAFC" CornerRadius="10" 
                        Margin="14,12,14,14" Padding="12,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="44"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Продукт" 
                                   Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="8,0"/>
                        <TextBlock Grid.Column="1" Text="Количество" 
                                   Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="2" Text="Ед." 
                                   Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="3" Text="" 
                                   Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" Margin="0,0,0,0">
            <ItemsControl Grid.Row="1" ItemsSource="{Binding Products}" Margin="0,4,0,0" d:ItemsSource="{d:SampleData ItemCount=2}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" CornerRadius="10" Padding="12,8" Margin="0,0,0,6"
                                BorderBrush="#F1F5F9" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="44"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox x:Name="ProductCombo" Grid.Column="0"
                                          ItemsSource="{Binding DataContext.AvailableProducts, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                                          SelectedItem="{Binding SelectedProduct, UpdateSourceTrigger=PropertyChanged}"
                                          DisplayMemberPath="Name"
                                          Height="38"
                                          Margin="0,0,8,0"
                                          Background="#F8FAFC"
                                          BorderBrush="#E2E8F0"
                                          BorderThickness="1"
                                          FontSize="13">
                                    <ComboBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </ComboBox.Resources>
                                </ComboBox>

                                <TextBox Grid.Column="1"
                                         Text="{Binding Quantity, StringFormat='N2', UpdateSourceTrigger=PropertyChanged}"
                                         Height="38"
                                         Margin="0,0,8,0"
                                         Background="#F8FAFC"
                                         BorderBrush="#E2E8F0"
                                         BorderThickness="1"
                                         TextAlignment="Center"
                                         FontSize="13">
                                    <TextBox.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </TextBox.Resources>
                                </TextBox>

                                <Border Grid.Column="2" Height="38" Background="#F1F5F9" CornerRadius="8" Margin="0,0,8,0">
                                    <TextBlock Text="{Binding SelectedProduct.Unit}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="#64748B"
                                               FontWeight="SemiBold"
                                               FontSize="13"/>
                                </Border>

                                <Button x:Name="DeleteProductBtn" Grid.Column="3"
                                        Content="🗑" 
                                        Width="38" Height="38"
                                        Click="DeleteProductBtn_Click"
                                        Tag="{Binding}" 
                                        ToolTip="Удалить продукт"
                                        Background="#FEE2E2"
                                        Foreground="#EF4444"
                                        BorderThickness="0"
                                        FontSize="14"
                                        Cursor="Hand">
                                    <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="8"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="3" Background="White" CornerRadius="14" Padding="18" 
                Margin="0,18,0,0" Effect="{StaticResource CardShadow}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" 
                        Content="Отмена"
                        Height="42" Width="110"
                        Margin="0,0,10,0"
                        Click="CancelBtn_Click"
                        Background="White"
                        Foreground="#64748B"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="SaveBtn" 
                        Content="💾  Сохранить"
                        Height="42" Width="140"
                        Click="SaveBtn_Click"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>