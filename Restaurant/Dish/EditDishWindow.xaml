<Window x:Class="Restaurant.Dish.EditDishWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant.Dish"
        xmlns:imgcon="clr-namespace:Restaurant.Product"
        mc:Ignorable="d"
        Title="EditDishWindow" Height="450" Width="800">
    <Window.Resources>
        <imgcon:ImagePathConverter x:Key="ImagePathConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="15" Background="#F5F5F5" CornerRadius="8" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" 
                        Width="150" Height="150"
                        Background="White" 
                        CornerRadius="10"
                        Margin="0,0,20,0"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1">
                    <Image x:Name="DishImage"
                           Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                           Stretch="Uniform"
                           Margin="5"/>
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Название:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="NameBox"
                             Text="{Binding DishName, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="16" Padding="8" Margin="0,0,0,10"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Цена:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <TextBox x:Name="PriceBox"
                                     Text="{Binding Price, StringFormat='N2', UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="16" Padding="8"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Категория:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox x:Name="CategoryCombo"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      DisplayMemberPath="CategoryName"
                      FontSize="14" Padding="5"/>
                                <Button Grid.Column="1" 
                    Content="📋" 
                    Width="30" Height="30"
                    Margin="5,0,0,0"
                    Click="CategoriesBtn_Click"
                    ToolTip="Список категорий"
                    Style="{StaticResource IconButtonStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Grid>

                    <Button x:Name="ChooseImageBtn" 
                            Content="📷 Выбрать изображение"
                            Width="150" Height="30"
                            Click="ChooseImageBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <Button x:Name="AddProductBtn" 
                    Content="➕ Добавить продукт" 
                    Width="160" Height="30"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="AddProductBtn_Click"/>
        </StackPanel>
        
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#E8E8E8" BorderBrush="#CCCCCC" 
                        BorderThickness="0,0,0,1" Padding="5">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                            <ColumnDefinition Width="30"/>
                            <ColumnDefinition Width="50"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Продукт" TextAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="1" Text="Кол-во" TextAlignment="Center" FontWeight="Bold"/>
                        <TextBlock Grid.Column="2" Text="" FontWeight="Bold"/>
                        <TextBlock Grid.Column="3" Text="" FontWeight="Bold"/>
                    </Grid>
                </Border>

                <ItemsControl Grid.Row="1" ItemsSource="{Binding Products}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="30"/>
                                        <ColumnDefinition Width="50"/>
                                    </Grid.ColumnDefinitions>

                                    <ComboBox x:Name="ProductCombo" Grid.Column="0"
                                              ItemsSource="{Binding DataContext.AvailableProducts, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                                              SelectedItem="{Binding SelectedProduct, UpdateSourceTrigger=PropertyChanged}"
                                              DisplayMemberPath="Name"
                                              Margin="0,0,5,0"/>

                                    <TextBox Grid.Column="1"
                                             Text="{Binding Quantity, StringFormat='N2', UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,5,0"/>

                                    <TextBlock Grid.Column="2" 
                                               Text="{Binding SelectedProduct.Unit}"
                                               VerticalAlignment="Center"/>

                                    <Button x:Name="DeleteProductBtn" Grid.Column="4"
                                            Content="🗑️" Width="25" Height="25"
                                            Click="DeleteProductBtn_Click"
                                            Tag="{Binding}" ToolTip="Удалить"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button x:Name="SaveBtn" Content="💾 Сохранить" 
                    Width="120" Height="35"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="SaveBtn_Click"/>
            <Button x:Name="CancelBtn" Content="Отмена" 
                    Width="100" Height="35" Margin="10,0,0,0"
                    Click="CancelBtn_Click"/>
        </StackPanel>
    </Grid>
</Window>
