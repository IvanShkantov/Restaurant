<Page x:Class="Restaurant.Dish.DishesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restaurant.Dish"
      xmlns:imgcon="clr-namespace:Restaurant.Product"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DishesPage" Background="White">
    <Page.Resources>
        <imgcon:ImagePathConverter x:Key="ImagePathConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="БЛЮДА" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button x:Name="CategoriesBtn" 
                Content="📋 Категории" 
                Width="120" Height="25" 
                Margin="15,0,0,0"
                VerticalAlignment="Center"
                Click="CategoriesBtn_Click"
                Style="{StaticResource SecondaryButtonStyle}"/>
            <Button x:Name="AddDishButt" Content="➕ Добавить блюдо" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="160" Height="35" HorizontalAlignment="Right" Click="AddDishButt_Click"/>
             
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding DishCategories}" d:ItemsSource="{d:SampleData ItemCount=4}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Vertical" IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Margin="10,5" ExpandDirection="Down" IsExpanded="True" 
                                  Background="#FFEAEAEA" Padding="10,0,0,0">
                            <Expander.Header>
                                <Border Background="White" CornerRadius="15" Margin="10">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding CategoryName}"
                                                   FontSize="20" Padding="10" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                            </Expander.Header>

                            <ItemsControl ItemsSource="{Binding Dishes}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="15"
                                                Margin="8"
                                                Width="280"
                                                Background="White">
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                    <RowDefinition Height="Auto"/>
                                                </Grid.RowDefinitions>

                                                <Border Grid.Row="0" 
                                                        Height="160" 
                                                        Background="#F8F9FA" 
                                                        CornerRadius="8"
                                                        Margin="0,0,0,10">
                                                    <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                                           Stretch="Uniform"
                                                           Margin="5"/>
                                                </Border>

                                                <TextBlock Grid.Row="1" 
                                                           Text="{Binding Name}"
                                                           FontWeight="Bold"
                                                           FontSize="16"
                                                           TextWrapping="Wrap"
                                                           TextAlignment="Center"
                                                           Margin="0,0,0,5"/>

                                                <TextBlock Grid.Row="2" 
                                                           Text="{Binding Price, StringFormat='C'}"
                                                           FontSize="18"
                                                           FontWeight="Bold"
                                                           Foreground="#007BFF"
                                                           TextAlignment="Center"
                                                           Margin="0,0,0,10"/>

                                                <StackPanel Grid.Row="3" 
                                                            Orientation="Horizontal" 
                                                            HorizontalAlignment="Center">
                                                    <Button x:Name="EditDishBtn" 
                                                            Content="✏️ Редактировать"
                                                            Height="30" Padding="10,0"
                                                            Click="EditDishBtn_Click"
                                                            Tag="{Binding DishID}"
                                                            Style="{StaticResource PrimaryButtonStyle}"/>
                                                    <Button x:Name="DeleteDishBtn" 
                                                            Width="35" Height="30"
                                                            Margin="5,0,0,0"
                                                            Click="DeleteDishBtn_Click"
                                                            Tag="{Binding DishID}"
                                                            ToolTip="Удалить блюдо">
                                                        <Image Source="/img/icons/remove.png" Width="18"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <Button Content="⬅️ Назад" Grid.Row="2" 
Width="100" Height="38"
Click="Back_Click"
Style="{StaticResource SecondaryButtonStyle}"
VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
    </Grid>
</Page>
