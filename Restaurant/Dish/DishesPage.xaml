<Page x:Class="Restaurant.Dish.DishesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restaurant.Dish"
      xmlns:imgcon="clr-namespace:Restaurant.Product"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="DishesPage" Background="#F8FAFC">
    <Page.Resources>
        <imgcon:ImagePathConverter x:Key="ImagePathConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="15" ShadowDepth="2" Direction="270" Opacity="0.1"/>
        <DropShadowEffect x:Key="HeaderShadow" BlurRadius="20" ShadowDepth="0" Opacity="0.05"/>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,25" Background="White" CornerRadius="16" Padding="20" Effect="{StaticResource HeaderShadow}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="БЛЮДА" FontSize="28" FontWeight="Bold" 
                               Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="CategoriesBtn" 
                    Content="📋 Категории" 
                    Height="36" Padding="16,0"
                    Margin="20,0,0,0"
                    VerticalAlignment="Center"
                    Click="CategoriesBtn_Click"
                    Background="#F1F5F9"
                    Foreground="#475569"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Cursor="Hand" HorizontalAlignment="Center">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="AddDishButt" 
                        Content="➕  Добавить блюдо"
                        Height="42" Padding="20,0"
                        HorizontalAlignment="Right" 
                        Click="AddDishButt_Click"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="12"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding DishCategories}" d:ItemsSource="{d:SampleData ItemCount=4}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,20" Background="White" CornerRadius="16" 
                                Padding="20" Effect="{StaticResource CardShadow}">
                            <StackPanel>
                                <Border Background="#F8FAFC" CornerRadius="12" Padding="14,10" Margin="0,0,0,15">
                                    <TextBlock Text="{Binding CategoryName}"
                                               FontSize="20" 
                                               FontWeight="Bold"
                                               Foreground="#1E293B"/>
                                </Border>
                                <ItemsControl ItemsSource="{Binding Dishes}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="14"
                                                    Padding="0"
                                                    Margin="0,0,14,14"
                                                    Width="260"
                                                    Background="White">
                                                <Border.Resources>
                                                    <DropShadowEffect x:Key="HoverShadow" BlurRadius="20" ShadowDepth="4" Opacity="0.08"/>
                                                </Border.Resources>
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="170"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Border Grid.Row="0" 
                                                            Background="#F8FAFC" 
                                                            CornerRadius="14,14,0,0">
                                                        <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}"
                                                               Stretch="UniformToFill"
                                                               Margin="0"/>
                                                    </Border>

                                                    <StackPanel Grid.Row="1" Margin="16,14,16,6">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="15"
                                                                   Foreground="#1E293B"
                                                                   TextWrapping="Wrap"
                                                                   TextAlignment="Left"
                                                                   MaxHeight="40"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Row="2" 
                                                               Text="{Binding Price, StringFormat='C'}"
                                                               FontSize="20"
                                                               FontWeight="Bold"
                                                               Foreground="#3B82F6"
                                                               TextAlignment="Left"
                                                               Margin="16,0,16,10"/>

                                                    <Border Grid.Row="3" Background="#F8FAFC" CornerRadius="0,0,14,14" Padding="12,10">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Button x:Name="EditDishBtn" 
                                                                    Content="✏️ Изменить"
                                                                    Height="34" 
                                                                    Padding="14,0"
                                                                    Click="EditDishBtn_Click"
                                                                    Tag="{Binding DishID}"
                                                                    Background="#3B82F6"
                                                                    Foreground="White"
                                                                    BorderThickness="0"
                                                                    FontWeight="SemiBold"
                                                                    FontSize="12"
                                                                    Cursor="Hand">
                                                                <Button.Resources>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="CornerRadius" Value="8"/>
                                                                    </Style>
                                                                </Button.Resources>
                                                            </Button>
                                                            <Button x:Name="DeleteDishBtn" 
                                                                    Grid.Column="1"
                                                                    Width="34" Height="34"
                                                                    Margin="8,0,0,0"
                                                                    Click="DeleteDishBtn_Click"
                                                                    Tag="{Binding DishID}"
                                                                    ToolTip="Удалить блюдо"
                                                                    Background="#FEE2E2"
                                                                    BorderThickness="0"
                                                                    Cursor="Hand">
                                                                <Button.Resources>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="CornerRadius" Value="8"/>
                                                                    </Style>
                                                                </Button.Resources>
                                                                <Image Source="/img/icons/remove.png" Width="16" Height="16"/>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Margin="0,20,0,0">
            <Button Content="←  Назад"
                    Height="40" Width="110"
                    HorizontalAlignment="Right"
                    Click="Back_Click"
                    Background="White"
                    Foreground="#64748B"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Border>
    </Grid>
</Page>