<Page x:Class="Restaurant.Product.WarehousePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restaurant.Product"
      xmlns:imgcon="clr-namespace:Restaurant.Product"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="WarehousePage" Background="White">

    <Page.Resources>
        <imgcon:ImagePathConverter x:Key="ImagePathConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <local:QuantityToColorConverter x:Key="QuantityToColorConverter"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="СКЛАД" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Border Background="#F8D7DA" CornerRadius="8" Padding="10,5">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="❌ Отсутствуют: " FontSize="13" FontWeight="SemiBold" Foreground="#721C24"/>
                        <TextBlock x:Name="ZeroStockCount" Text="0" FontSize="13" FontWeight="Bold" Foreground="#721C24"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" 
                Background="#F8F9FA" 
                CornerRadius="8,8,0,0" 
                Padding="15,10"
                BorderBrush="#DEE2E6"
                BorderThickness="1,1,1,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="" FontWeight="Bold"/>
                <TextBlock Grid.Column="1" Text="Продукт" FontWeight="Bold" FontSize="13" Margin="10,0"/>
                <TextBlock Grid.Column="2" Grid.ColumnSpan="2" Text="Остаток" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="Статус" FontWeight="Bold" FontSize="13" HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Categories}" d:ItemsSource="{d:SampleData ItemCount=4}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Margin="0,0,0,0" 
                                  ExpandDirection="Down" 
                                  IsExpanded="True" 
                                  Padding="0">
                            <Expander.Header>
                                <Border Background="#F0F0F0" CornerRadius="0" Padding="12,10"
                                        BorderBrush="#DEE2E6" BorderThickness="1,1,1,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📁" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding CategoryName}"
                                                   FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Products.Count, StringFormat=' ({0} продуктов)'}" 
                                                   FontSize="13" Foreground="#6C757D" 
                                                   VerticalAlignment="Center" Margin="5,0,0,0"/>

                                        <TextBlock Foreground="#DC3545" FontSize="12" VerticalAlignment="Center" Margin="20,0,0,0"
                                                   Visibility="{Binding HasZeroStock, Converter={StaticResource BoolToVis}}">
                                            <Run Text="Нулевой остаток: "/>
                                            <Run Text="{Binding ZeroStockCount}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Expander.Header>

                            <ItemsControl ItemsSource="{Binding Products}" 
                                          BorderBrush="#DEE2E6" 
                                          BorderThickness="1,0,1,1">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="10,8"
                                                BorderBrush="#E5E7EB"
                                                BorderThickness="0,0,0,1">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Quantity}" Value="0">
                                                            <Setter Property="Background" Value="#FFF5F5"/>
                                                            <Setter Property="BorderBrush" Value="#FFD0D0"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="100"/>
                                                    <ColumnDefinition Width="50"/>
                                                    <ColumnDefinition Width="170"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" 
                                                        Width="45" Height="45"
                                                        Background="White" 
                                                        CornerRadius="8"
                                                        BorderBrush="#E5E7EB"
                                                        BorderThickness="1">
                                                    <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}" 
                                                           Stretch="Uniform" Margin="3"/>
                                                </Border>

                                                <TextBlock Grid.Column="1" 
                                                           Text="{Binding Name}" 
                                                           VerticalAlignment="Center"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Margin="15,0,0,0"/>

                                                <TextBlock Grid.Column="2" 
                                                           Text="{Binding Quantity, StringFormat='N2'}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="18" FontWeight="Bold"
                                                           Foreground="{Binding Quantity, Converter={StaticResource QuantityToColorConverter}}"/>

                                                <TextBlock Grid.Column="3" 
                                                           Text="{Binding Unit}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           FontSize="13"
                                                           Foreground="#6C757D"/>

                                                <StackPanel Grid.Column="4" 
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center">
                                                    <Border CornerRadius="10" Padding="8,3" 
                                                            Background="#F8D7DA"
                                                            Visibility="{Binding IsZeroStock, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="❌ Нет в наличии" FontSize="11" FontWeight="Bold" 
                                                                   Foreground="#721C24"/>
                                                    </Border>

                                                    <Border CornerRadius="10" Padding="8,3" 
                                                            Background="#D4EDDA"
                                                            Visibility="{Binding IsInStock, Converter={StaticResource BoolToVis}}">
                                                        <TextBlock Text="✅ В наличии" FontSize="11" FontWeight="Bold" 
                                                                   Foreground="#155724"/>
                                                    </Border>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <Button Content="⬅️ Назад" Grid.Row="3" 
Width="100" Height="38"
Click="Back_Click"
Style="{StaticResource SecondaryButtonStyle}"
VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
    </Grid>
</Page>
