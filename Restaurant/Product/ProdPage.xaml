<Page x:Class="Restaurant.Product.ProdPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:Restaurant.Product"
      mc:Ignorable="d"
      Title="ProdPage" Background="#F8FAFC">

    <Page.Resources>
        <local:ImagePathConverter x:Key="ImagePathConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DropShadowEffect x:Key="HeaderShadow" BlurRadius="20" ShadowDepth="0" Opacity="0.05"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="12" ShadowDepth="2" Opacity="0.06"/>
        <DropShadowEffect x:Key="ProductShadow" BlurRadius="8" ShadowDepth="1" Opacity="0.05"/>

        <Style TargetType="Grid" x:Key="ManagementButtonsStyle">
            <Setter Property="Visibility" Value="Hidden"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource FindAncestor, AncestorType=Border}}" 
                                   Value="True"/>
                        <Condition Binding="{Binding DataContext.CanEdit, RelativeSource={RelativeSource FindAncestor, AncestorType=Page}}" 
                                   Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,22" Background="White" CornerRadius="16" Padding="20" Effect="{StaticResource HeaderShadow}">
            <Grid>
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Продукты" FontSize="28" FontWeight="Bold" 
                               Foreground="#1E293B" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="CategoriesBtn" 
                            Content="📋 Категории"
                            Height="36" Padding="16,0"
                            Margin="20,0,0,0"
                            VerticalAlignment="Center"
                            Click="CategoriesBtn_Click"
                            Background="#F1F5F9"
                            Foreground="#475569"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand" HorizontalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Grid.Column="2" x:Name="AddProdButt" 
                        Content="➕  Добавить продукт"
                        Height="42" Padding="20,0"
                        HorizontalAlignment="Right"
                        Click="AddProdButt_Click"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Categories}" d:ItemsSource="{d:SampleData ItemCount=6}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,18" Background="White" CornerRadius="16" 
                                Padding="20" Effect="{StaticResource CardShadow}">
                            <StackPanel>
                                <Border Background="#F8FAFC" CornerRadius="12" Padding="14,12" Margin="0,0,0,16">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding CategoryName}"
                                                   FontSize="18" 
                                                   FontWeight="Bold"
                                                   Foreground="#1E293B"/>
                                        <TextBlock Text="{Binding Products.Count, StringFormat='({0} продуктов)'}" 
                                                   FontSize="13" 
                                                   Foreground="#94A3B8" 
                                                   VerticalAlignment="Center"
                                                   Margin="10,0,0,0"/>
                                    </StackPanel>
                                </Border>

                                <ItemsControl ItemsSource="{Binding Products}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>

                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border BorderBrush="#E2E8F0"
                                                    BorderThickness="1"
                                                    CornerRadius="12"
                                                    Padding="0"
                                                    Margin="0,0,12,12"
                                                    Width="220"
                                                    Background="White"
                                                    Effect="{StaticResource ProductShadow}">
                                                <Grid>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="120"/>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Border Grid.Row="0" 
                                                            Background="#F8FAFC" 
                                                            CornerRadius="12,12,0,0">
                                                        <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}" 
                                                               Stretch="Uniform" Margin="12"/>
                                                    </Border>

                                                    <Grid x:Name="ManagementBtns" Grid.Row="0" 
                                                          HorizontalAlignment="Right" 
                                                          VerticalAlignment="Top"
                                                          Margin="0,8,8,0"
                                                          Style="{StaticResource ManagementButtonsStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button x:Name="EditBtn" 
                                                                    Width="30" Height="30"
                                                                    Click="EditBtn_Click"
                                                                    Tag="{Binding ProductID}"
                                                                    ToolTip="Редактировать"
                                                                    Background="White"
                                                                    BorderBrush="#E2E8F0"
                                                                    BorderThickness="1"
                                                                    Cursor="Hand">
                                                                <Button.Resources>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="CornerRadius" Value="8"/>
                                                                    </Style>
                                                                </Button.Resources>
                                                                <Image Source="/img/icons/edit.png" Width="14" Height="14"/>
                                                            </Button>
                                                            <Button x:Name="DeleteBtn" 
                                                                    Width="30" Height="30"
                                                                    Margin="4,0,0,0"
                                                                    Click="DeleteBtn_Click"
                                                                    Tag="{Binding ProductID}"
                                                                    ToolTip="Удалить"
                                                                    Background="White"
                                                                    BorderBrush="#E2E8F0"
                                                                    BorderThickness="1"
                                                                    Cursor="Hand">
                                                                <Button.Resources>
                                                                    <Style TargetType="Border">
                                                                        <Setter Property="CornerRadius" Value="8"/>
                                                                    </Style>
                                                                </Button.Resources>
                                                                <Image Source="/img/icons/remove.png" Width="14" Height="14"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>

                                                    <StackPanel Grid.Row="1" Margin="14,12,14,6">
                                                        <TextBlock Text="{Binding Name}" 
                                                                   FontWeight="SemiBold" 
                                                                   TextWrapping="Wrap" 
                                                                   TextAlignment="Left" 
                                                                   FontSize="14" 
                                                                   Foreground="#1E293B"
                                                                   MaxHeight="40"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                    </StackPanel>

                                                    <TextBlock Grid.Row="2" 
                                                               Text="{Binding Unit, StringFormat='({0})'}"
                                                               FontSize="12"
                                                               Foreground="#FF6C7889"
                                                               Margin="14,0,14,12"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="0" Margin="0,18,0,0">
            <Button Content="←  Назад"
                    Height="40" Width="110"
                    HorizontalAlignment="Right"
                    Click="Back_Click"
                    Background="White"
                    Foreground="#64748B"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Border>
    </Grid>
</Page>