<Page x:Class="Restaurant.Product.ProdPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant.Product"
        mc:Ignorable="d"
        Title="ProdPage">

    <Page.Resources>
        <local:ImagePathConverter x:Key="ImagePathConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style TargetType="Grid" x:Key="ManagementButtonsStyle">
            <Setter Property="Visibility" Value="Hidden"/>
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource FindAncestor, AncestorType=Border}}" 
                                   Value="True"/>
                        <Condition Binding="{Binding DataContext.CanEdit, RelativeSource={RelativeSource FindAncestor, AncestorType=Page}}" 
                                   Value="True"/>
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Visibility" Value="Visible"/>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20" Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="ПРОДУКТЫ" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button x:Name="AddProdButt" Content="➕ Добавить продукт" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="180" Height="35" HorizontalAlignment="Right" Click="AddProdButt_Click"/>
            <Button x:Name="CategoriesBtn" 
                Content="📋 Категории" 
                Width="120" Height="25" 
                Margin="15,0,0,0"
                VerticalAlignment="Center"
                Click="CategoriesBtn_Click"
                Style="{StaticResource SecondaryButtonStyle}"/>
        </Grid>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Categories}" d:ItemsSource="{d:SampleData ItemCount=6}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Vertical" IsItemsHost="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Margin="10,5" ExpandDirection="Down" IsExpanded="True" 
                                  Background="#FFEAEAEA" Padding="10,0,0,0">
                            <Expander.Header>
                                <Border Background="White" CornerRadius="15" Margin="10"
                                        BorderBrush="#E0E0E0" BorderThickness="1">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding CategoryName}"
                                                   FontSize="20" Padding="10" FontWeight="Bold"/>
                                        <TextBlock Text="{Binding Products.Count, StringFormat='({0} продуктов)'}" 
                                                   FontSize="14" Foreground="#6C757D" 
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>
                            </Expander.Header>

                            <ItemsControl ItemsSource="{Binding Products}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" IsItemsHost="True"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#E5E7EB"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="15"
                                                Margin="8"
                                                Width="250"
                                                Background="White">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0" 
                                                        Height="90" Width="90"
                                                        Background="White" 
                                                        CornerRadius="15"
                                                        BorderBrush="#E5E7EB"
                                                        BorderThickness="1">
                                                    <Image Source="{Binding ImagePath, Converter={StaticResource ImagePathConverter}}" 
                                                           Stretch="Uniform" Margin="5"/>
                                                </Border>

                                                <Grid Grid.Column="1">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="*"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <Grid x:Name="ManagementBtns" Grid.Row="0" 
                                                          HorizontalAlignment="Right" 
                                                          Style="{StaticResource ManagementButtonsStyle}">
                                                        <StackPanel Orientation="Horizontal">
                                                            <Button x:Name="EditBtn" 
                                                                    Margin="0,0,5,0" 
                                                                    Width="25" Height="25"
                                                                    Click="EditBtn_Click"
                                                                    Tag="{Binding ProductID}"
                                                                    ToolTip="Редактировать">
                                                                <Image Source="/img/icons/edit.png" Width="18"/>
                                                            </Button>
                                                            <Button x:Name="DeleteBtn" 
                                                                    Width="25" Height="25"
                                                                    Click="DeleteBtn_Click"
                                                                    Tag="{Binding ProductID}"
                                                                    ToolTip="Удалить">
                                                                <Image Source="/img/icons/remove.png" Width="18"/>
                                                            </Button>
                                                        </StackPanel>
                                                    </Grid>

                                                    <TextBlock Grid.Row="1" 
                                                               Text="{Binding Name}" 
                                                               VerticalAlignment="Center"
                                                               FontWeight="Bold" 
                                                               TextWrapping="Wrap" 
                                                               TextAlignment="Center" 
                                                               FontSize="14" 
                                                               Margin="6,0,0,0"/>

                                                    <TextBlock Grid.Row="2" 
                                                               Text="{Binding Unit, StringFormat='({0})'}"
                                                               FontWeight="SemiBold" 
                                                               TextAlignment="Center"
                                                               HorizontalAlignment="Center" 
                                                               FontSize="13"
                                                               Foreground="#6C757D" />
                                                </Grid>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Content="⬅ НАЗАД" Grid.Row="2" 
                HorizontalAlignment="Left" VerticalAlignment="Center" 
                Click="Back_Click"
                Style="{StaticResource SecondaryButtonStyle}"/>
    </Grid>
</Page>
