<Window x:Class="Restaurant.Product.EditProdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant.Product"
        mc:Ignorable="d"
        Title="EditProdWindow" HorizontalAlignment="Center" VerticalAlignment="Center" SizeToContent="WidthAndHeight" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
    <Window.Resources>
        <local:ImagePathConverter x:Key="ImagePathConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Border BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="10"
                Padding="20"
                Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <Border Grid.Row="0" 
                        Height="200" Width="200"
                        Background="#F8F9FA" 
                        CornerRadius="10"
                        Margin="0,0,0,15"
                        BorderBrush="#E5E7EB"
                        BorderThickness="1"
                        HorizontalAlignment="Center">
                    <Image x:Name="ProductImage"
                           Source="{Binding Product.ImagePath, Converter={StaticResource ImagePathConverter}}"
                           Stretch="Uniform" Margin="5"/>
                </Border>

                <Button Grid.Row="1" 
                        Content="📷 Выбрать изображение"
                        Width="200" Height="30"
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        Click="ChooseImageBtn_Click"/>

                <Grid Grid.Row="2" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="250"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" 
                               Text="Название:" 
                               VerticalAlignment="Center" Margin="0,0,10,10"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding Product.Name, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" Padding="5" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" 
                               Text="Ед. измерения:" 
                               VerticalAlignment="Center" Margin="0,0,10,10"
                               FontWeight="SemiBold"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Text="{Binding Product.Unit, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" Padding="5" Margin="0,0,0,10"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" 
                               Text="Категория:" 
                               VerticalAlignment="Center" Margin="0,0,10,0"
                               FontWeight="SemiBold"/>
                    <Grid Grid.Row="2" Grid.Column="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                              ItemsSource="{Binding Categories}" 
                              DisplayMemberPath="CategoryName" 
                              SelectedValuePath="CategoryID" 
                              SelectedValue="{Binding Product.CategoryID, Mode=TwoWay}"
                              FontSize="14" Padding="5"/>
                        <Button Grid.Column="1" 
                                Content="📋" 
                                Width="30" Height="30"
                                Margin="5,0,0,0"
                                Click="CategoriesBtn_Click"
                                ToolTip="Список категорий"
                                Style="{StaticResource IconButtonStyle}"/>
                    </Grid>
                </Grid>

                <StackPanel Grid.Row="4" Orientation="Horizontal" 
                            HorizontalAlignment="Right" Margin="0,20,0,0">
                    <Button x:Name="SaveButt" 
                            Content="💾 Сохранить" 
                            Width="120" Height="35"
                            Style="{StaticResource PrimaryButtonStyle}" 
                            Click="SaveButt_Click"/>
                    <Button x:Name="CancelButt" 
                            Content="Отмена" 
                            Width="100" Height="35" 
                            Margin="10,0,0,0"
                            Click="CancelBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
