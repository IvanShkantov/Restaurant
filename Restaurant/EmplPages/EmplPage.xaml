<Page x:Class="Restaurant.EmplPages.EmplPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant"
        mc:Ignorable="d"
        Title="EmplPage" Background="White">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="СОТРУДНИКИ" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            
            <Button x:Name="PositionsBtn" 
                Content="📋 Должности и права" 
                Width="160" Height="25" 
                Margin="15,0,0,0"
                VerticalAlignment="Center"
                Click="PositionsBtn_Click"
                Style="{StaticResource SecondaryButtonStyle}"/>
            
            <Button x:Name="AddEmployeeBtn" Content="➕ Добавить сотрудника" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="200" Height="35" HorizontalAlignment="Right" Click="AddEmployeeBtn_Click"/>
        </Grid>

        <Border Grid.Row="1" 
                Background="#F8F9FA" 
                CornerRadius="8,8,0,0" 
                Padding="15,10"
                BorderBrush="#DEE2E6"
                BorderThickness="1,1,1,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="60"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="" FontWeight="Bold"/>
                <TextBlock Grid.Column="1" Text="Фамилия" FontWeight="Bold" FontSize="13" Margin="5,0"/>
                <TextBlock Grid.Column="2" Text="Имя" FontWeight="Bold" FontSize="13" Margin="5,0"/>
                <TextBlock Grid.Column="3" Text="Отчество" FontWeight="Bold" FontSize="13" Margin="5,0"/>
                <TextBlock Grid.Column="4" Text="Должность" FontWeight="Bold" FontSize="13" Margin="5,0"/>
                <TextBlock Grid.Column="5" Text="Действия" FontWeight="Bold" FontSize="13" 
                           HorizontalAlignment="Center"/>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Employees}" d:ItemsSource="{d:SampleData ItemCount=6}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#DEE2E6"
                                BorderThickness="1,0,1,1"
                                Padding="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActivated}" Value="False">
                                            <Setter Property="Background" Value="#FFFDE7"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" 
                                        Width="40" Height="40"
                                        Background="#E8F4FD" 
                                        CornerRadius="20"
                                        BorderThickness="1"
                                        HorizontalAlignment="Center">
                                    <Image Source="/img/icons/user.png"
                                               HorizontalAlignment="Center" 
                                               VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Column="1" 
                                           Text="{Binding LName}" 
                                           VerticalAlignment="Center"
                                           FontSize="14" Margin="5,0"/>

                                <TextBlock Grid.Column="2" 
                                           Text="{Binding FName}" 
                                           VerticalAlignment="Center"
                                           FontSize="14" Margin="5,0"/>

                                <TextBlock Grid.Column="3" 
                                           Text="{Binding MName, TargetNullValue='—'}" 
                                           VerticalAlignment="Center"
                                           FontSize="14" Margin="5,0"/>

                                <StackPanel Grid.Column="4" Orientation="Horizontal" 
                                            VerticalAlignment="Center" Margin="5,0">
                                    <TextBlock Text="{Binding Positions.PositionName}" 
                                               FontSize="13"/>
                                    <Border CornerRadius="8" Padding="5,2" Margin="10,0,0,0"
                                            Background="#FFF3CD">

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActivated}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Не активирован" FontSize="10" Foreground="#856404"/>
                                    </Border>
                                </StackPanel>

                                <StackPanel Grid.Column="5" Orientation="Horizontal" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Content="✏️" 
                                            Width="35" Height="35"
                                            Click="EditEmployee_Click"
                                            Tag="{Binding EmployeeID}"
                                            ToolTip="Редактировать"
                                            Style="{StaticResource IconButtonStyle}"/>
                                    <Button Content="🗑️" 
                                            Width="35" Height="35"
                                            Click="DeleteEmployee_Click"
                                            Tag="{Binding EmployeeID}"
                                            ToolTip="Удалить"
                                            Margin="5,0,0,0">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EmployeeID}" Value="1">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.4"/>
                                                        <Setter Property="ToolTip" Value="Администратора удалить нельзя"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <Button Content="⬅️ Назад" Grid.Row="3" 
Width="100" Height="38"
Click="Back_Click"
Style="{StaticResource SecondaryButtonStyle}"
VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
    </Grid>
</Page>
