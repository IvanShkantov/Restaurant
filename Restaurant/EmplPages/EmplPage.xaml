<Page x:Class="Restaurant.EmplPages.EmplPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:local="clr-namespace:Restaurant"
      mc:Ignorable="d"
      Title="EmplPage" Background="#F8FAFC" d:Width="1404" d:DesignWidth="922">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DropShadowEffect x:Key="HeaderShadow" BlurRadius="20" ShadowDepth="0" Opacity="0.05"/>
        <DropShadowEffect x:Key="TableShadow" BlurRadius="12" ShadowDepth="2" Opacity="0.06"/>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,22" Background="White" CornerRadius="16" Padding="20" Effect="{StaticResource HeaderShadow}">
            <Grid>
                <Grid VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Сотрудники" FontSize="28" FontWeight="Bold" 
                               Foreground="#1E293B" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="PositionsBtn" 
                            Content="📋 Должности и права"
                            Height="36" Padding="16,0"
                            Margin="20,0,0,0"
                            VerticalAlignment="Center"
                            Click="PositionsBtn_Click"
                            Background="#F1F5F9"
                            Foreground="#475569"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand" HorizontalAlignment="Center">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Grid.Column="2" x:Name="AddEmployeeBtn" 
                        Content="➕  Добавить сотрудника"
                        Height="42" Padding="20,0"
                        HorizontalAlignment="Right"
                        Click="AddEmployeeBtn_Click"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="12"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
                
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="14,14,0,0" 
                Padding="0" Effect="{StaticResource TableShadow}">
            <Grid>
                <Border Background="#F8FAFC" CornerRadius="12,12,0,0" Padding="18,14" Margin="8,8,8,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12"/>
                        <TextBlock Grid.Column="1" Text="ФАМИЛИЯ" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="8,0"/>
                        <TextBlock Grid.Column="2" Text="ИМЯ" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="8,0"/>
                        <TextBlock Grid.Column="3" Text="ОТЧЕСТВО" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="8,0"/>
                        <TextBlock Grid.Column="4" Text="ДОЛЖНОСТЬ" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="8,0"/>
                        <TextBlock Grid.Column="5" Text="ДЕЙСТВИЯ" Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Employees}" d:ItemsSource="{d:SampleData ItemCount=3}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border 
                                BorderBrush="#F1F5F9"
                                BorderThickness="0,0,0,1"
                                Padding="14,10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsActivated}" Value="False">
                                            <Setter Property="Background" Value="#FFFBEB"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="60"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="130"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" 
                                        Width="42" Height="42"
                                        Background="#EFF6FF" 
                                        CornerRadius="21"
                                        HorizontalAlignment="Center"
                                        BorderBrush="#BFDBFE"
                                        BorderThickness="1">
                                    <Image Source="/img/icons/user.png"
                                           Width="35" Height="35"
                                           HorizontalAlignment="Center" 
                                           VerticalAlignment="Center"/>
                                </Border>

                                <TextBlock Grid.Column="1" 
                                           Text="{Binding LName}" 
                                           VerticalAlignment="Center"
                                           FontSize="14" FontWeight="SemiBold"
                                           Foreground="#1E293B" Margin="8,0"/>

                                <TextBlock Grid.Column="2" 
                                           Text="{Binding FName}" 
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           Foreground="#334155" Margin="8,0"/>

                                <TextBlock Grid.Column="3" 
                                           Text="{Binding MName, TargetNullValue='—'}" 
                                           VerticalAlignment="Center"
                                           FontSize="14"
                                           Foreground="#334155" Margin="8,0"/>

                                <Grid Grid.Column="4"
                                            VerticalAlignment="Center" Margin="8,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Positions.PositionName}" 
                                               FontSize="13" FontWeight="Medium"
                                               Foreground="#475569"/>
                                    <Border Grid.Column="1" CornerRadius="6" Padding="8,3" Margin="10,0,0,0"
                                            Background="#FEF3C7" HorizontalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActivated}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="Не активирован" FontSize="11" 
                                                   Foreground="#92400E" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>

                                <StackPanel Grid.Column="5" Orientation="Horizontal" 
                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <Button Content="✏️" 
                                            Width="34" Height="34"
                                            Click="EditEmployee_Click"
                                            Tag="{Binding EmployeeID}"
                                            ToolTip="Редактировать"
                                            Background="#EFF6FF"
                                            Foreground="#3B82F6"
                                            BorderThickness="0"
                                            FontSize="14"
                                            Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                    <Button Content="🗑" 
                                            Width="34" Height="34"
                                            Click="DeleteEmployee_Click"
                                            Tag="{Binding EmployeeID}"
                                            ToolTip="Удалить"
                                            Margin="6,0,0,0"
                                            Background="#FEE2E2"
                                            Foreground="#EF4444"
                                            BorderThickness="0"
                                            FontSize="14"
                                            Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding EmployeeID}" Value="1">
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                        <Setter Property="Opacity" Value="0.35"/>
                                                        <Setter Property="ToolTip" Value="Администратора удалить нельзя"/>
                                                        <Setter Property="Background" Value="#F1F5F9"/>
                                                        <Setter Property="Foreground" Value="#94A3B8"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="3" Padding="0" Margin="0,18,0,0">
            <Button Content="←  Назад"
                    Height="40" Width="110"
                    HorizontalAlignment="Right"
                    Click="Back_Click"
                    Background="White"
                    Foreground="#64748B"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Border>
    </Grid>
</Page>