<Window x:Class="Restaurant.EmplPages.EditEmployeeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant.EmplPages"
        mc:Ignorable="d"
        Title="Редактирование сотрудника"
        Background="#F8FAFC"
        WindowStartupLocation="CenterScreen" SizeToContent="WidthAndHeight" d:DesignWidth="378.292">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="2" Opacity="0.08"/>
        <DropShadowEffect x:Key="AvatarShadow" BlurRadius="12" ShadowDepth="3" Opacity="0.1"/>
    </Window.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   x:Name="TitleText"
                   Text="Новый сотрудник" 
                   FontSize="22" FontWeight="Bold" 
                   Foreground="#1E293B"
                   Margin="0,0,0,22"
                   HorizontalAlignment="Center"/>

        <Border Grid.Row="1" 
                Width="90" Height="90"
                Background="#EFF6FF" 
                CornerRadius="45"
                Margin="0,0,0,22"
                BorderBrush="#BFDBFE"
                BorderThickness="2"
                HorizontalAlignment="Center"
                Effect="{StaticResource AvatarShadow}">
            <Image x:Name="EmployeeIcon"
                   Width="80" Height="80"
                   Stretch="Uniform">
                <Image.Style>
                    <Style TargetType="Image">
                        <Setter Property="Source" Value="/img/icons/user.png"/>
                    </Style>
                </Image.Style>
            </Image>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="14" Padding="20" Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="Фамилия" FontWeight="SemiBold" 
                           Foreground="#64748B" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="LNameBox"
                         Text="{Binding LastName, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="15" Padding="12,10"
                         FontWeight="Medium"
                         Background="#F8FAFC"
                         BorderBrush="#E2E8F0"
                         BorderThickness="1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>
        </Border>

        <Border Grid.Row="3" Background="White" CornerRadius="14" Padding="20" 
                Margin="0,10,0,0" Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="Имя" FontWeight="SemiBold" 
                           Foreground="#64748B" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="FNameBox"
                         Text="{Binding FirstName, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="15" Padding="12,10"
                         FontWeight="Medium"
                         Background="#F8FAFC"
                         BorderBrush="#E2E8F0"
                         BorderThickness="1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>
        </Border>

        <Border Grid.Row="4" Background="White" CornerRadius="14" Padding="20" 
                Margin="0,10,0,0" Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="Отчество" FontWeight="SemiBold" 
                           Foreground="#64748B" FontSize="12" Margin="0,0,0,5"/>
                <TextBox x:Name="MNameBox"
                         Text="{Binding MiddleName, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="15" Padding="12,10"
                         FontWeight="Medium"
                         Background="#F8FAFC"
                         BorderBrush="#E2E8F0"
                         BorderThickness="1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
            </StackPanel>
        </Border>

        <Border Grid.Row="5" Background="White" CornerRadius="14" Padding="20" 
                Margin="0,10,0,0" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Должность" FontWeight="SemiBold" 
                               Foreground="#64748B" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding Positions}"
                              SelectedItem="{Binding SelectedPosition}"
                              DisplayMemberPath="PositionName"
                              FontSize="14" 
                              Padding="10,8"
                              Background="#F8FAFC"
                              BorderBrush="#E2E8F0"
                              BorderThickness="1">
                        <ComboBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>
                <Button Grid.Column="1" 
                        Content="📋" 
                        Width="40" Height="40"
                        Margin="8,20,0,0"
                        VerticalAlignment="Bottom"
                        Click="PositionsBtn_Click"
                        ToolTip="Управление должностями"
                        Background="#F1F5F9"
                        BorderThickness="0"
                        FontSize="16"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="6" Background="White" CornerRadius="14" Padding="20" 
                Margin="0,10,0,0" Effect="{StaticResource CardShadow}"
                Visibility="{Binding IsNewEmployee, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock Text="Пригласительный код" FontWeight="SemiBold" 
                               Foreground="#64748B" FontSize="12" Margin="0,0,0,5"/>
                    <TextBox x:Name="InviteCodeBox"
                             Text="{Binding InviteCode, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                             FontSize="15" Padding="12,10"
                             FontWeight="Medium"
                             IsReadOnly="True"
                             Background="#F8FAFC"
                             BorderBrush="#E2E8F0"
                             BorderThickness="1"
                             Foreground="#3B82F6"
                             FontFamily="Consolas">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>
                <Button Grid.Column="1" 
                        Content="🎲"
                        Width="40" Height="40"
                        Margin="8,20,0,0"
                        VerticalAlignment="Bottom"
                        Click="GenerateInviteCode_Click"
                        ToolTip="Сгенерировать новый код"
                        Background="#EFF6FF"
                        Foreground="#3B82F6"
                        BorderThickness="0"
                        FontSize="16"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="8" Margin="0,18,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelBtn" 
                        Content="Отмена"
                        Height="42" Width="110"
                        Margin="0,0,10,0"
                        Click="CancelBtn_Click"
                        Background="White"
                        Foreground="#64748B"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="SaveBtn" 
                        Content="💾  Сохранить"
                        Height="42" Width="140"
                        Click="SaveBtn_Click"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>