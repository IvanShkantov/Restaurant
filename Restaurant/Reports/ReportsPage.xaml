<Page x:Class="Restaurant.Reports.ReportsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restaurant.Reports"
      mc:Ignorable="d"
      Title="ReportsPage" Background="#F8FAFC">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DropShadowEffect x:Key="HeaderShadow" BlurRadius="20" ShadowDepth="0" Opacity="0.05"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="12" ShadowDepth="2" Opacity="0.06"/>
        <DropShadowEffect x:Key="StatCardShadow" BlurRadius="15" ShadowDepth="3" Opacity="0.08"/>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,18" Background="White" CornerRadius="16" Padding="20" Effect="{StaticResource HeaderShadow}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="Итоги работы предприятия" FontSize="26" FontWeight="Bold" 
                           Foreground="#1E293B" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="14" Padding="18" Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center" ItemHeight="40">

                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="Тип отчёта" FontWeight="SemiBold" 
                               Foreground="#64748B" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <ComboBox x:Name="ReportTypeCombo"
                              ItemsSource="{Binding ReportTypes}"
                              SelectedItem="{Binding SelectedReportType}"
                              Width="150"
                              FontSize="13"
                              Padding="8,6"
                              Background="#F8FAFC"
                              BorderBrush="#E2E8F0"
                              BorderThickness="1">
                        <ComboBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>

                <Border Width="1" Background="#E2E8F0" Margin="4,6,16,6"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Дата с" FontWeight="SemiBold" 
                               Foreground="#64748B" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <DatePicker x:Name="DateFromPicker" 
                                SelectedDate="{Binding FilterDateFrom, Mode=TwoWay}"
                                Width="125" FontSize="13"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <TextBlock Text="Дата по" FontWeight="SemiBold" 
                               Foreground="#64748B" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <DatePicker x:Name="DateToPicker" 
                                SelectedDate="{Binding FilterDateTo, Mode=TwoWay}"
                                Width="125" FontSize="13"/>
                </StackPanel>

                <Border Width="1" Background="#E2E8F0" Margin="4,6,16,6"/>

                <CheckBox Content="Группировать по месяцам"
                          IsChecked="{Binding GroupByMonth}"
                          VerticalAlignment="Center" Margin="0,0,16,0"
                          FontWeight="Medium" Foreground="#475569"/>

                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock x:Name="EmployeeFilterLabel" 
                               Text="Сотрудник" FontWeight="SemiBold" 
                               Foreground="#64748B" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <ComboBox x:Name="EmployeeFilterCombo"
                              ItemsSource="{Binding Employees}"
                              SelectedItem="{Binding SelectedEmployee}"
                              DisplayMemberPath="FullName"
                              Width="160"
                              FontSize="13"
                              Padding="8,6"
                              Background="#F8FAFC"
                              BorderBrush="#E2E8F0"
                              BorderThickness="1">
                        <ComboBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock x:Name="SupplierFilterLabel" 
                               Text="Поставщик" FontWeight="SemiBold" 
                               Foreground="#64748B" FontSize="12" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <ComboBox x:Name="SupplierFilterCombo"
                              ItemsSource="{Binding Suppliers}"
                              SelectedItem="{Binding SelectedSupplier}"
                              DisplayMemberPath="Name"
                              Width="160"
                              FontSize="13"
                              Padding="8,6"
                              Background="#F8FAFC"
                              BorderBrush="#E2E8F0"
                              BorderThickness="1">
                        <ComboBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>

                <Button x:Name="ExportButt" 
                        Content="📄  Экспорт"
                        Height="38" Padding="14,0"
                        Click="ExportButt_Click"
                        Background="#EFF6FF"
                        Foreground="#2563EB"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="9"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </WrapPanel>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,18">

            <Border x:Name="RevenueCard" 
                    Background="White" 
                    CornerRadius="14" 
                    Padding="22,18" 
                    Margin="0,0,14,0"
                    Effect="{StaticResource StatCardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="ВЫРУЧКА" FontWeight="SemiBold" FontSize="11" 
                                   Foreground="#94A3B8" Margin="0,0,0,6"/>
                        <TextBlock x:Name="RevenueValue" 
                                   Text="$0,00" 
                                   FontWeight="Bold" FontSize="28"
                                   Foreground="#10B981"/>
                        <TextBlock x:Name="RevenueDetail" 
                                   Text="0 заказов" 
                                   FontSize="12" Foreground="#94A3B8" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="ExpensesCard" 
                    Background="White" 
                    CornerRadius="14" 
                    Padding="22,18" 
                    Margin="0,0,14,0"
                    Effect="{StaticResource StatCardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="РАСХОДЫ" FontWeight="SemiBold" FontSize="11" 
                                   Foreground="#94A3B8" Margin="0,0,0,6"/>
                        <TextBlock x:Name="ExpensesValue" 
                                   Text="$0,00" 
                                   FontWeight="Bold" FontSize="28"
                                   Foreground="#EF4444"/>
                        <TextBlock x:Name="ExpensesDetail" 
                                   Text="0 закупок" 
                                   FontSize="12" Foreground="#94A3B8" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border x:Name="ProfitCard" 
                    Background="White" 
                    CornerRadius="14" 
                    Padding="22,18"
                    Effect="{StaticResource StatCardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="ПРИБЫЛЬ" FontWeight="SemiBold" FontSize="11" 
                                   Foreground="#94A3B8" Margin="0,0,0,6"/>
                        <TextBlock x:Name="ProfitValue" 
                                   Text="$0,00" 
                                   FontWeight="Bold" FontSize="28"
                                   Foreground="#3B82F6"/>
                        <TextBlock x:Name="ProfitDetail" 
                                   Text="" 
                                   FontSize="12" Foreground="#94A3B8" Margin="0,6,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Border Grid.Row="3" Background="White" CornerRadius="12" Padding="16,12" Margin="0,0,0,12" Effect="{StaticResource CardShadow}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="📋" FontSize="18" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <TextBlock x:Name="OperationsTitle" 
                           Text="Список операций" 
                           FontSize="16" FontWeight="Bold" 
                           Foreground="#1E293B"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="OperationsItemsControl">

                <ItemsControl.Resources>
                    <DataTemplate x:Key="GroupHeaderTemplate" DataType="{x:Type local:OperationGroup}">
                        <Border Background="White" 
                                CornerRadius="12"
                                Padding="18,14"
                                Margin="0,12,0,4"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                Effect="{StaticResource CardShadow}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" 
                                        Background="#EFF6FF" 
                                        CornerRadius="10" 
                                        Padding="14,8" 
                                        Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📅" FontSize="16" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                        <TextBlock Text="{Binding GroupTitle}" 
                                                   FontWeight="Bold" 
                                                   FontSize="15"
                                                   VerticalAlignment="Center"
                                                   Foreground="#1E40AF"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Grid.Column="1" 
                                           Text="{Binding SummaryText}"
                                           FontSize="13"
                                           Foreground="#64748B"
                                           VerticalAlignment="Center"
                                           Margin="10,0"/>

                                <Border Grid.Column="2" 
                                        Background="#F8FAFC" 
                                        CornerRadius="10" 
                                        Padding="14,8">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding TotalCount}" 
                                                   FontWeight="Bold" 
                                                   FontSize="15"
                                                   Foreground="#1E293B"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text=" операций" 
                                                   FontSize="12"
                                                   Foreground="#94A3B8"
                                                   VerticalAlignment="Center"
                                                   Margin="4,0,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>

                    <DataTemplate x:Key="OrderTemplate" DataType="{x:Type local:OperationViewModel}">
                        <Border Background="White" 
                                CornerRadius="10" 
                                Padding="16,12"
                                Margin="28,0,0,6"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" 
                                        Background="#D1FAE5" 
                                        CornerRadius="16" 
                                        Padding="12,5" 
                                        Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="ЗАКАЗ" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="11"
                                                   Foreground="#065F46"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Grid.Column="1" 
                                           Text="{Binding OperationDate, StringFormat='dd.MM.yyyy HH:mm'}"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           Foreground="#94A3B8"
                                           Margin="0,0,16,0"/>

                                <TextBlock Grid.Column="2" 
                                           Text="{Binding EmployeeName}"
                                           VerticalAlignment="Center"
                                           FontSize="13"
                                           Foreground="#475569"/>

                                <Border Grid.Column="3" Background="#ECFDF5" CornerRadius="8" Padding="12,6">
                                    <TextBlock Text="{Binding Amount, StringFormat='C'}"
                                               FontWeight="Bold" 
                                               Foreground="#059669"
                                               VerticalAlignment="Center"
                                               FontSize="14"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>

                    <DataTemplate x:Key="PurchaseTemplate" DataType="{x:Type local:OperationViewModel}">
                        <Border Background="White"
                                CornerRadius="10"
                                Padding="16,12"
                                Margin="28,0,0,6"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" 
                                        Background="#FEF3C7" 
                                        CornerRadius="16" 
                                        Padding="12,5" 
                                        Margin="0,0,16,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📦" FontSize="12" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                        <TextBlock Text="ЗАКУПКА" 
                                                   FontWeight="SemiBold" 
                                                   FontSize="11"
                                                   Foreground="#92400E"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding SupplierName}"
                                               FontWeight="SemiBold"
                                               FontSize="13"
                                               Foreground="#1E293B"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                        <TextBlock Text="{Binding OperationDate, StringFormat='dd.MM.yyyy HH:mm'}"
                                                   FontSize="12"
                                                   Foreground="#94A3B8"/>
                                        <TextBlock Text=" • "
                                                   FontSize="12"
                                                   Foreground="#94A3B8"/>
                                        <TextBlock Text="{Binding EmployeeName}"
                                                   FontSize="12"
                                                   Foreground="#64748B"/>
                                    </StackPanel>
                                </StackPanel>

                                <Border Grid.Column="2" Background="#EFF6FF" CornerRadius="8" Padding="12,6">
                                    <TextBlock Text="{Binding Amount, StringFormat='C'}"
                                               FontWeight="Bold" 
                                               Foreground="#2563EB"
                                               VerticalAlignment="Center"
                                               FontSize="14"/>
                                </Border>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.Resources>

                <ItemsControl.ItemTemplateSelector>
                    <local:OperationTemplateSelector 
                        GroupHeaderTemplate="{StaticResource GroupHeaderTemplate}"
                        OrderTemplate="{StaticResource OrderTemplate}"
                        PurchaseTemplate="{StaticResource PurchaseTemplate}"/>
                </ItemsControl.ItemTemplateSelector>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="5" Margin="0,18,0,0">
            <Button Content="←  Назад"
                    Height="40" Width="110"
                    HorizontalAlignment="Right"
                    Click="Back_Click"
                    Background="White"
                    Foreground="#64748B"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Border>
    </Grid>
</Page>