<Page x:Class="Restaurant.Order.OrderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restaurant.Order"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OrderPage" Background="White">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="10,3"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="ЗАКАЗЫ" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button x:Name="AddOrderButt" Content="➕ Создать заказ" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="180" Height="35" HorizontalAlignment="Right" Click="AddOrderButt_Click"/>
        </Grid>

        <TextBlock Text="Активные" TextAlignment="Center" Grid.Row="1" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ActiveOrders}" d:ItemsSource="{d:SampleData ItemCount=3}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Margin="0,0,0,10" IsExpanded="False">
                            <Expander.Header>
                                <Border Background="#F5F5F5" CornerRadius="8" Padding="15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Created">
                                                            <Setter Property="Background" Value="#FFF3CD"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Processing">
                                                            <Setter Property="Background" Value="#CCE5FF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Ready">
                                                            <Setter Property="Background" Value="#D4EDDA"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" FontSize="12"/>
                                        </Border>

                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}"
                                                   FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,0,0"/>

                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding EmployeeFullName}"
                                                   Margin="20,0,0,0" VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="3" 
                                                   Text="{Binding ItemsCount, StringFormat='Позиций: {0}'}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="4" 
                                                   Text="{Binding TotalOrderPrice, StringFormat='C'}"
                                                   FontWeight="Bold" Foreground="#007BFF"
                                                   VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="6" Orientation="Horizontal">
                                            <Button x:Name="NextStatusButt" 
                                                    Width="35" Height="35" Margin="5,0"
                                                    DataContext="{Binding OrderID}"
                                                    Content="{Binding NextStatusIcon}"
                                                    ToolTip="{Binding NextStatusTooltip}" 
                                                    Click="NextStatusButt_Click"/>


                                            <Button x:Name="EditOrderButt" Content="✏️" 
                                                    Width="35" Height="35" Margin="5,0"
                                                    DataContext="{Binding OrderID}"
                                                    ToolTip="Редактировать" Click="EditOrderButt_Click"/>

                                            <Button x:Name="CancelOrderButt" Width="35" Height="35" Margin="5,0" 
                                                    DataContext="{Binding OrderID}" ToolTip="Отменить заказ" Click="CancelOrderButt_Click">
                                                <Image Source="/img/icons/remove.png" Width="20"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </Expander.Header>

                            <Border BorderBrush="#DDD" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                                <DataGrid ItemsSource="{Binding Items}" 
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          Margin="10">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Блюдо" 
                                                            Binding="{Binding DishName}" 
                                                            Width="*"/>
                                        <DataGridTextColumn Header="Количество" 
                                                            Binding="{Binding Quantity, StringFormat='N0'}" 
                                                            Width="100"/>
                                        <DataGridTextColumn Header="Цена за ед." 
                                                            Binding="{Binding UnitPrice, StringFormat='C'}" 
                                                            Width="120"/>
                                        <DataGridTextColumn Header="Сумма" 
                                                            Binding="{Binding TotalPrice, StringFormat='C'}" 
                                                            Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <TextBlock Text="Завершённые" TextAlignment="Center" Grid.Row="3" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding CompletedOrders}" d:ItemsSource="{d:SampleData ItemCount=3}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander Margin="0,0,0,10" IsExpanded="False">
                            <Expander.Header>
                                <Border Background="#F5F5F5" CornerRadius="8" Padding="15">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="150"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" 
                                                   Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}"
                                                   FontWeight="Bold" VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1" 
                                                   Text="{Binding ClosedAt, StringFormat='dd.MM.yyyy HH:mm'}"
                                                   FontWeight="Bold" VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2" 
                                                   Text="{Binding EmployeeFullName}"
                                                   Margin="20,0,0,0" VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="3" 
                                                   Text="{Binding ItemsCount, StringFormat='Позиций: {0}'}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="4" 
                                                   Text="{Binding TotalOrderPrice, StringFormat='C'}"
                                                   FontWeight="Bold" Foreground="#28A745"
                                                   VerticalAlignment="Center"/>

                                        <Border Grid.Column="5" Background="#D4EDDA" CornerRadius="12" Padding="10,3">
                                            <TextBlock Text="✅ Завершён" FontWeight="SemiBold" FontSize="12" Foreground="#155724"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </Expander.Header>

                            <Border BorderBrush="#DDD" BorderThickness="1,0,1,1" CornerRadius="0,0,8,8">
                                <DataGrid ItemsSource="{Binding Items}" 
                                          AutoGenerateColumns="False"
                                          IsReadOnly="True"
                                          HeadersVisibility="Column"
                                          Margin="10">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Блюдо" 
                                                            Binding="{Binding DishName}" 
                                                            Width="*"/>
                                        <DataGridTextColumn Header="Количество" 
                                                            Binding="{Binding Quantity, StringFormat='N0'}" 
                                                            Width="100"/>
                                        <DataGridTextColumn Header="Цена за ед." 
                                                            Binding="{Binding UnitPrice, StringFormat='C'}" 
                                                            Width="120"/>
                                        <DataGridTextColumn Header="Сумма" 
                                                            Binding="{Binding TotalPrice, StringFormat='C'}" 
                                                            Width="120"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Border>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
        <Button Content="⬅️ Назад" Grid.Row="5" 
Width="100" Height="38"
Click="Back_Click"
Style="{StaticResource SecondaryButtonStyle}"
VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
    </Grid>
</Page>
