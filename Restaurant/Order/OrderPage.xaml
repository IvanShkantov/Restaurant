<Page x:Class="Restaurant.Order.OrderPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restaurant.Order"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OrderPage" Background="#F8FAFC">

    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DropShadowEffect x:Key="HeaderShadow" BlurRadius="20" ShadowDepth="0" Opacity="0.05"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="12" ShadowDepth="2" Opacity="0.06"/>

        <Style x:Key="StatusBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,22" Background="White" CornerRadius="16" Padding="20" Effect="{StaticResource HeaderShadow}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Заказы" FontSize="28" FontWeight="Bold" 
                               Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="AddOrderButt" 
                        Content="➕  Создать заказ"
                        Height="42" Padding="20,0"
                        HorizontalAlignment="Right"
                        Click="AddOrderButt_Click"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="12"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#EFF6FF" CornerRadius="12" Padding="14,10" Margin="0,0,0,18">
            <TextBlock Text="Активные заказы" FontSize="18" FontWeight="Bold" 
                       Foreground="#1E40AF" HorizontalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding ActiveOrders}" d:ItemsSource="{d:SampleData ItemCount=3}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" Background="White" CornerRadius="14" 
                                Effect="{StaticResource CardShadow}" Padding="0">
                            <Expander IsExpanded="False" BorderThickness="0">
                                <Expander.Header >
                                    <Border Padding="50,14" CornerRadius="14" Background="Transparent" 
                                            HorizontalAlignment="Stretch" Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Expander}, Path=ActualWidth}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0">
                                                <Border.Style>
                                                    <Style TargetType="Border" BasedOn="{StaticResource StatusBadgeStyle}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Created">
                                                                <Setter Property="Background" Value="#FEF3C7"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Processing">
                                                                <Setter Property="Background" Value="#DBEAFE"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Status}" Value="Ready">
                                                                <Setter Property="Background" Value="#D1FAE5"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding StatusText}" FontWeight="SemiBold" FontSize="12"
                                                           Foreground="#1E293B"/>
                                            </Border>

                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}"
                                                       FontWeight="SemiBold" FontSize="13"
                                                       Foreground="#475569"
                                                       VerticalAlignment="Center" Margin="18,0,0,0"/>

                                            <TextBlock Grid.Column="2" 
                                                       Text="{Binding EmployeeFullName}"
                                                       FontSize="13" Foreground="#64748B"
                                                       Margin="20,0,0,0" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="3" 
                                                       Text="{Binding ItemsCount, StringFormat='Позиций: {0}'}"
                                                       FontSize="13" Foreground="#64748B"
                                                       VerticalAlignment="Center" Margin="0,0,16,0"/>

                                            <TextBlock Grid.Column="4" 
                                                       Text="{Binding TotalOrderPrice, StringFormat='C'}"
                                                       FontWeight="Bold" FontSize="16"
                                                       Foreground="#3B82F6"
                                                       VerticalAlignment="Center" Margin="0,0,18,0"/>

                                            <StackPanel Grid.Column="5" Orientation="Horizontal">
                                                <Button x:Name="NextStatusButt" 
                                                    Width="36" Height="36" Margin="0,0,4,0"
                                                    Tag="{Binding OrderID}"
                                                    Content="{Binding NextStatusIcon}"
                                                    ToolTip="{Binding NextStatusTooltip}" 
                                                    Click="NextStatusButt_Click"
                                                    Background="#EFF6FF"
                                                    Foreground="#3B82F6"
                                                    BorderThickness="0"
                                                    FontSize="14"
                                                    Cursor="Hand">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="9"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>

                                                <Button x:Name="EditOrderButt" 
                                                        Content="✏️"
                                                        Width="36" Height="36" Margin="0,0,4,0"
                                                        DataContext="{Binding OrderID}"
                                                        ToolTip="Редактировать" 
                                                        Click="EditOrderButt_Click"
                                                        Background="#F1F5F9"
                                                        Foreground="#475569"
                                                        BorderThickness="0"
                                                        FontSize="14"
                                                        Cursor="Hand">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="9"/>
                                                        </Style>
                                                    </Button.Resources>
                                                </Button>

                                                <Button x:Name="CancelOrderButt" 
                                                        Width="36" Height="36"
                                                        DataContext="{Binding OrderID}" 
                                                        ToolTip="Отменить заказ" 
                                                        Click="CancelOrderButt_Click"
                                                        Background="#FEE2E2"
                                                        BorderThickness="0"
                                                        Cursor="Hand">
                                                    <Button.Resources>
                                                        <Style TargetType="Border">
                                                            <Setter Property="CornerRadius" Value="9"/>
                                                        </Style>
                                                    </Button.Resources>
                                                    <Image Source="/img/icons/remove.png" Width="16" Height="16"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Expander.Header>

                                <Border Background="#F8FAFC" CornerRadius="0,0,14,14" Padding="16">
                                    <DataGrid ItemsSource="{Binding Items}" 
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              Background="White"
                                              RowBackground="White"
                                              AlternatingRowBackground="#F8FAFC"
                                              BorderThickness="0"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#E2E8F0">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="Foreground" Value="#64748B"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="Padding" Value="12,10"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                            </Style>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Margin" Value="12,10"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Foreground" Value="#334155"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Блюдо" 
                                                                Binding="{Binding DishName}" 
                                                                Width="*"/>
                                            <DataGridTextColumn Header="Количество" 
                                                                Binding="{Binding Quantity, StringFormat='N0'}" 
                                                                Width="100"/>
                                            <DataGridTextColumn Header="Цена за ед." 
                                                                Binding="{Binding UnitPrice, StringFormat='C'}"
                                                                Width="130"/>
                                            <DataGridTextColumn Header="Сумма" 
                                                                Binding="{Binding TotalPrice, StringFormat='C'}"
                                                                Width="130">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="#3B82F6"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Expander>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="3" Background="#F0FDF4" CornerRadius="12" Padding="14,10" Margin="0,18,0,18">
            <TextBlock Text="✅ Завершённые заказы" FontSize="18" FontWeight="Bold" 
                       Foreground="#166534" HorizontalAlignment="Center"/>
        </Border>

        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding CompletedOrders}" d:ItemsSource="{d:SampleData ItemCount=3}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,12" Background="White" CornerRadius="14" 
                                Effect="{StaticResource CardShadow}" Padding="0">
                            <Expander IsExpanded="False" BorderThickness="0">
                                <Expander.Header>
                                    <Border Padding="50,14" CornerRadius="14" Background="Transparent"
                                            HorizontalAlignment="Stretch" Width="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=Expander}, Path=ActualWidth}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="1" 
                                                       Text="{Binding ClosedAt, StringFormat='dd.MM.yyyy HH:mm'}"
                                                       FontWeight="SemiBold" FontSize="13"
                                                       Foreground="#475569"
                                                       VerticalAlignment="Center" Margin="18,0,0,0"/>

                                            <TextBlock Grid.Column="2" 
                                                       Text="{Binding EmployeeFullName}"
                                                       FontSize="13" Foreground="#64748B"
                                                       Margin="20,0,0,0" VerticalAlignment="Center"/>

                                            <TextBlock Grid.Column="3" 
                                                       Text="{Binding ItemsCount, StringFormat='Позиций: {0}'}"
                                                       FontSize="13" Foreground="#64748B"
                                                       VerticalAlignment="Center" Margin="0,0,16,0"/>

                                            <TextBlock Grid.Column="4" 
                                                       Text="{Binding TotalOrderPrice, StringFormat='C'}"
                                                       FontWeight="Bold" FontSize="16"
                                                       Foreground="#10B981"
                                                       VerticalAlignment="Center" Margin="0,0,18,0"/>

                                            <Border Grid.Column="5" 
                                                    Background="#D1FAE5" 
                                                    CornerRadius="20" 
                                                    Padding="14,6">
                                                <TextBlock Text="✅ Завершён" FontWeight="SemiBold" 
                                                           FontSize="12" Foreground="#065F46"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Expander.Header>

                                <Border Background="#F8FAFC" CornerRadius="0,0,14,14" Padding="16">
                                    <DataGrid ItemsSource="{Binding Items}" 
                                              AutoGenerateColumns="False"
                                              IsReadOnly="True"
                                              HeadersVisibility="Column"
                                              Background="White"
                                              RowBackground="White"
                                              AlternatingRowBackground="#F8FAFC"
                                              BorderThickness="0"
                                              GridLinesVisibility="Horizontal"
                                              HorizontalGridLinesBrush="#E2E8F0">
                                        <DataGrid.Resources>
                                            <Style TargetType="DataGridColumnHeader">
                                                <Setter Property="Background" Value="White"/>
                                                <Setter Property="Foreground" Value="#64748B"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter Property="FontSize" Value="12"/>
                                                <Setter Property="Padding" Value="12,10"/>
                                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                                <Setter Property="BorderBrush" Value="#E2E8F0"/>
                                            </Style>
                                            <Style TargetType="DataGridCell">
                                                <Setter Property="Margin" Value="12,10"/>
                                                <Setter Property="FontSize" Value="13"/>
                                                <Setter Property="Foreground" Value="#334155"/>
                                                <Setter Property="BorderThickness" Value="0"/>
                                            </Style>
                                        </DataGrid.Resources>
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="Блюдо" 
                                                                Binding="{Binding DishName}" 
                                                                Width="*"/>
                                            <DataGridTextColumn Header="Количество" 
                                                                Binding="{Binding Quantity, StringFormat='N0'}" 
                                                                Width="100"/>
                                            <DataGridTextColumn Header="Цена за ед." 
                                                                Binding="{Binding UnitPrice, StringFormat='C'}"
                                                                Width="130"/>
                                            <DataGridTextColumn Header="Сумма" 
                                                                Binding="{Binding TotalPrice, StringFormat='C'}"
                                                                Width="130">
                                                <DataGridTextColumn.ElementStyle>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                                        <Setter Property="Foreground" Value="#10B981"/>
                                                    </Style>
                                                </DataGridTextColumn.ElementStyle>
                                            </DataGridTextColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>
                                </Border>
                            </Expander>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Border Grid.Row="5" Padding="0" Margin="0,18,0,0">
            <Button Content="←  Назад"
                    Height="40" Width="110"
                    HorizontalAlignment="Right"
                    Click="Back_Click"
                    Background="White"
                    Foreground="#64748B"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Border>
    </Grid>
</Page>