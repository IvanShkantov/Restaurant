<Window x:Class="Restaurant.Order.EditOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant.Order"
        mc:Ignorable="d"
        Title="Редактирование заказа"
        Background="#F8FAFC"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="20" ShadowDepth="2" Opacity="0.08"/>
        <DropShadowEffect x:Key="SummaryShadow" BlurRadius="15" ShadowDepth="0" Opacity="0.06"/>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="20" Background="White" CornerRadius="14" 
                Margin="0,0,0,16" Effect="{StaticResource CardShadow}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Width="40" Height="40" Background="#EFF6FF" CornerRadius="10">
                    <TextBlock Text="👤" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Сотрудник" FontSize="11" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding EmployeeFullName}"
                               FontWeight="Bold" FontSize="15"
                               Foreground="#1E293B"/>
                </StackPanel>

                <Border Grid.Column="2" Width="1" Background="#E2E8F0" Margin="20,6"/>

                <StackPanel Grid.Column="3" VerticalAlignment="Center">
                    <TextBlock Text="Дата создания" FontSize="11" Foreground="#94A3B8" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding OrderDate, StringFormat='dd.MM.yyyy HH:mm'}"
                               FontWeight="SemiBold" FontSize="14"
                               Foreground="#475569"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="18" Background="White" CornerRadius="14" 
                Margin="0,0,0,6" Effect="{StaticResource CardShadow}">
            <Grid>
                <Button x:Name="AddItemButt" 
                        Content="➕  Добавить блюдо"
                        Height="40" Padding="16,0"
                        HorizontalAlignment="Left"
                        Click="AddItemButt_Click"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <Border HorizontalAlignment="Right" Background="#F0FDF4" 
                        CornerRadius="10" Padding="18,10">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Итого к оплате:" FontSize="13" 
                                   Foreground="#047857" FontWeight="Medium"
                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding EstimatedTotalPrice, StringFormat='C'}" 
                                   FontSize="20" FontWeight="Bold" 
                                   Foreground="#059669"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Border Background="White" CornerRadius="14" Effect="{StaticResource CardShadow}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="14,14,0,0" 
                            Padding="16,12" Margin="0,0,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="110"/>
                                <ColumnDefinition Width="50"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Блюдо" 
                                       Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="8,0"/>
                            <TextBlock Grid.Column="1" Text="Количество" 
                                       Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="8,0"/>
                            <TextBlock Grid.Column="2" Text="Цена" 
                                       Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="8,0"/>
                            <TextBlock Grid.Column="3" Text="Сумма" 
                                       Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="8,0"/>
                            <TextBlock Grid.Column="4" Text="" 
                                       Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12"/>
                        </Grid>
                    </Border>

                    <ItemsControl Grid.Row="1" ItemsSource="{Binding Items}" 
                                  d:ItemsSource="{d:SampleData ItemCount=4}" Margin="0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F1F5F9" 
                                        BorderThickness="0,0,0,1"
                                        Padding="14,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="110"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>

                                        <ComboBox x:Name="DishCB" Grid.Column="0"
                                                  ItemsSource="{Binding DataContext.AvailableDishes, RelativeSource={RelativeSource FindAncestor, AncestorType=Window}}"
                                                  SelectedItem="{Binding SelectedDish, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayMemberPath="Name"
                                                  Height="38"
                                                  Margin="0,0,8,0"
                                                  Background="#F8FAFC"
                                                  BorderBrush="#E2E8F0"
                                                  BorderThickness="1"
                                                  FontSize="13">
                                            <ComboBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="8"/>
                                                </Style>
                                            </ComboBox.Resources>
                                        </ComboBox>

                                        <TextBox Grid.Column="1"
                                                 Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="38"
                                                 Margin="0,0,8,0"
                                                 Background="#F8FAFC"
                                                 BorderBrush="#E2E8F0"
                                                 BorderThickness="1"
                                                 TextAlignment="Center"
                                                 FontSize="13"
                                                 FontWeight="Medium">
                                            <TextBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="8"/>
                                                </Style>
                                            </TextBox.Resources>
                                        </TextBox>

                                        <Border Grid.Column="2" Height="38" 
                                                Background="#F8FAFC" CornerRadius="8" 
                                                Margin="0,0,8,0" Padding="10,0">
                                            <TextBlock Text="{Binding UnitPrice, StringFormat='C'}"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       Foreground="#64748B"
                                                       FontWeight="Medium"/>
                                        </Border>

                                        <Border Grid.Column="3" Height="38" 
                                                Background="#EFF6FF" CornerRadius="8" 
                                                Margin="0,0,8,0" Padding="10,0">
                                            <TextBlock Text="{Binding TotalPrice, StringFormat='C'}"
                                                       VerticalAlignment="Center"
                                                       FontSize="13"
                                                       Foreground="#3B82F6"
                                                       FontWeight="Bold"/>
                                        </Border>

                                        <Button x:Name="DeleteItemButt" Grid.Column="4"
                                                Content="🗑"
                                                Width="38" Height="38"
                                                DataContext="{Binding}"
                                                ToolTip="Удалить позицию" 
                                                Click="DeleteItemButt_Click"
                                                Background="#FEE2E2"
                                                Foreground="#EF4444"
                                                BorderThickness="0"
                                                FontSize="14"
                                                Cursor="Hand">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="8"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>
        </ScrollViewer>

        <Border Grid.Row="3" Margin="0,16,0,0">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButt" 
                        Content="Отмена"
                        Height="42" Width="110"
                        Margin="0,0,10,0"
                        Click="CancelButt_Click"
                        Background="White"
                        Foreground="#64748B"
                        BorderBrush="#E2E8F0"
                        BorderThickness="1"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="SaveButt" 
                        Content="💾  Сохранить заказ"
                        Height="42" Width="160"
                        Click="SaveButt_Click"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>