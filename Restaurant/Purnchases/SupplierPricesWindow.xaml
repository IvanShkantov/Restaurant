<Window x:Class="Restaurant.Purnchases.SupplierPricesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant.Purnchases"
        xmlns:imgcon="clr-namespace:Restaurant.Product"
        mc:Ignorable="d"
        Title="Цены поставщика"
        Background="#F8FAFC"
        WindowStartupLocation="CenterScreen" d:DesignWidth="461.88">
    <Window.Resources>
        <imgcon:ImagePathConverter x:Key="ImagePathConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DropShadowEffect x:Key="CardShadow" BlurRadius="12" ShadowDepth="2" Opacity="0.06"/>
        <DropShadowEffect x:Key="ImageShadow" BlurRadius="8" ShadowDepth="2" Opacity="0.08"/>
        <DropShadowEffect x:Key="HeaderShadow" BlurRadius="20" ShadowDepth="0" Opacity="0.05"/>
    </Window.Resources>

    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,16" Background="White" CornerRadius="16" Padding="20" Effect="{StaticResource HeaderShadow}">
            <Grid>
                <StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="SupplierNameTitle" 
                                   FontSize="22" FontWeight="Bold" 
                                   Foreground="#1E293B"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Управление ценами на продукты" 
                               FontSize="13" Foreground="#94A3B8" 
                               Margin="0,4,0,0"/>
                </StackPanel>
                <Button x:Name="AddPriceButt" 
                        Content="➕  Добавить цену"
                        Height="40" Padding="16,0"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="AddPriceButt_Click"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        FontSize="13"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="10"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Border x:Name="AddPricePanel"
                Grid.Row="1" 
                Background="White" 
                CornerRadius="14" 
                Padding="20" 
                Margin="0,0,0,14"
                Effect="{StaticResource CardShadow}"
                BorderBrush="#BFDBFE"
                BorderThickness="1"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Продукт" FontWeight="SemiBold" 
                               Foreground="#64748B" FontSize="12" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ProductCombo"
                              DisplayMemberPath="Name"
                              FontSize="14" 
                              Padding="10,8"
                              Background="#F8FAFC"
                              BorderBrush="#E2E8F0"
                              BorderThickness="1">
                        <ComboBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </ComboBox.Resources>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="1" Margin="20,0">
                    <TextBlock Text="Цена" FontWeight="SemiBold" 
                               Foreground="#64748B" FontSize="12" Margin="0,0,0,5"/>
                    <Grid>
                        <TextBox x:Name="PriceBox"
                                 FontSize="16" 
                                 FontWeight="Bold"
                                 Text="0,00"
                                 Width="130"
                                 Padding="12,10"
                                 TextAlignment="Center"
                                 Background="#F8FAFC"
                                 BorderBrush="#E2E8F0"
                                 BorderThickness="1">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="10"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <TextBlock Text="$" FontSize="16" Foreground="#94A3B8" 
                                   VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,12,0"/>
                    </Grid>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button x:Name="SavePriceBtn" 
                            Content="💾  Сохранить"
                            Height="40" Width="120"
                            Click="SavePriceBtn_Click"
                            Background="#3B82F6"
                            Foreground="White"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            FontSize="13"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button x:Name="CancelAddBtn" 
                            Content="Отмена"
                            Height="40" Width="90"
                            Margin="8,0,0,0"
                            Click="CancelAddBtn_Click"
                            Background="White"
                            Foreground="#64748B"
                            BorderBrush="#E2E8F0"
                            BorderThickness="1"
                            FontWeight="SemiBold"
                            FontSize="13"
                            Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="10"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Prices}" d:ItemsSource="{d:SampleData ItemCount=3}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Margin="0,0,0,10" Background="White" CornerRadius="14" 
                                Padding="18" Effect="{StaticResource CardShadow}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Background" Value="#FFFBEB"/>
                                            <Setter Property="BorderBrush" Value="#FCD34D"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsNew}" Value="True">
                                            <Setter Property="Background" Value="#F0FDF4"/>
                                            <Setter Property="BorderBrush" Value="#86EFAC"/>
                                            <Setter Property="BorderThickness" Value="1"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" 
                                        Width="90" Height="90"
                                        Background="#F8FAFC" 
                                        CornerRadius="12"
                                        Margin="0,0,18,0"
                                        BorderBrush="#E2E8F0"
                                        BorderThickness="1"
                                        Effect="{StaticResource ImageShadow}">
                                    <Image x:Name="ProductImage"
                                           Source="{Binding Product.ImagePath, Converter={StaticResource ImagePathConverter}}"
                                           Stretch="Uniform"
                                           Margin="8"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Product.Name}" 
                                                   FontSize="17" FontWeight="Bold"
                                                   Foreground="#1E293B"
                                                   VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding Product.Unit, StringFormat='({0})'}" 
                                                   FontSize="13" Foreground="#94A3B8"
                                                   VerticalAlignment="Center" Margin="8,0,0,0"/>
                                    </StackPanel>

                                    <TextBlock Text="{Binding Product.ProdCategories.CategoryName}" 
                                               FontSize="12" Foreground="#94A3B8"
                                               Margin="0,4,0,0"/>

                                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                        <TextBlock Text="Цена:" 
                                                   VerticalAlignment="Center" 
                                                   FontSize="14"
                                                   Foreground="#64748B"
                                                   Margin="0,0,10,0"/>

                                        <TextBlock x:Name="PriceText"
                                                   Text="{Binding Price.Price, StringFormat='C'}"
                                                   FontSize="22" FontWeight="Bold"
                                                   Foreground="#3B82F6"
                                                   VerticalAlignment="Center"
                                                   Visibility="Visible"/>

                                        <TextBox x:Name="PriceEditBox"
                                                 Text="{Binding Price.Price, StringFormat='N2', UpdateSourceTrigger=PropertyChanged}"
                                                 FontSize="16" FontWeight="Bold"
                                                 TextAlignment="Center"
                                                 Width="120"
                                                 Padding="10,8"
                                                 Background="White"
                                                 BorderBrush="#E2E8F0"
                                                 BorderThickness="1"
                                                 Visibility="Collapsed">
                                            <TextBox.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="8"/>
                                                </Style>
                                            </TextBox.Resources>
                                        </TextBox>
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="12,0,0,0">
                                    <Button x:Name="EditButton"
                                            Content="✏️  Изменить"
                                            Height="38" Padding="14,0"
                                            Click="EditPrice_Click"
                                            Tag="{Binding}"
                                            ToolTip="Изменить цену"
                                            Visibility="Visible"
                                            Background="#EFF6FF"
                                            Foreground="#3B82F6"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            FontSize="13"
                                            Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="9"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>

                                    <Button x:Name="SaveButton"
                                            Content="💾  Сохранить"
                                            Height="38" Padding="14,0"
                                            Click="SavePrice_Click"
                                            Tag="{Binding}"
                                            ToolTip="Сохранить цену"
                                            Visibility="Collapsed"
                                            Background="#10B981"
                                            Foreground="White"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            FontSize="13"
                                            Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="9"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>

                                    <Button x:Name="CancelEditButton"
                                            Content="↩  Отменить"
                                            Height="38" Padding="14,0"
                                            Margin="0,6,0,0"
                                            Click="CancelEditPrice_Click"
                                            Tag="{Binding}"
                                            ToolTip="Отменить редактирование"
                                            Visibility="Collapsed"
                                            Background="#F1F5F9"
                                            Foreground="#64748B"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            FontSize="13"
                                            Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="9"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>

                                    <Button x:Name="DeleteButton"
                                            Content="🗑  Удалить"
                                            Height="38" Padding="14,0"
                                            Margin="0,10,0,0"
                                            Click="DeletePrice_Click"
                                            Tag="{Binding}"
                                            ToolTip="Удалить цену"
                                            Background="#FEE2E2"
                                            Foreground="#EF4444"
                                            BorderThickness="0"
                                            FontWeight="SemiBold"
                                            FontSize="13"
                                            Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="9"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>