<Window x:Class="Restaurant.Purnchases.SupplierPricesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant.Purnchases"
        xmlns:imgcon="clr-namespace:Restaurant.Product"
        mc:Ignorable="d"
        Title="SupplierPricesWindow" Height="450" Width="800">
    <Window.Resources>
        <imgcon:ImagePathConverter x:Key="ImagePathConverter"/>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="ProductCardStyle" TargetType="Border">
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Padding" Value="15"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="PriceTextBoxStyle" TargetType="TextBox">
            <Setter Property="Width" Value="100"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#80BDFF"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <StackPanel>
                <TextBlock x:Name="SupplierNameTitle" 
                           FontSize="24" FontWeight="Bold" 
                           VerticalAlignment="Center"/>
                <TextBlock Text="Управление ценами на продукты" 
                           FontSize="14" Foreground="#6C757D" 
                           Margin="0,5,0,0"/>
            </StackPanel>

            <Button x:Name="AddPriceButt" 
                    Content="➕ Добавить цену" 
                    Style="{StaticResource PrimaryButtonStyle}"
                    Width="160" Height="35" 
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Click="AddPriceButt_Click"/>
        </Grid>

        <Border x:Name="AddPricePanel"
                Grid.Row="1" 
                Background="#F0F8FF" 
                CornerRadius="8" 
                Padding="15" 
                Margin="0,0,0,15"
                BorderBrush="#BAE0FF"
                BorderThickness="1"
                Visibility="Collapsed">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Выберите продукт:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <ComboBox x:Name="ProductCombo"
                              DisplayMemberPath="Name"
                              Width="300"
                              HorizontalAlignment="Left"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Цена:" FontWeight="SemiBold" Margin="0,0,0,5"/>
                    <TextBox x:Name="PriceBox"
                             Style="{StaticResource PriceTextBoxStyle}"
                             Text="0,00"/>
                </StackPanel>

                <StackPanel Grid.Column="2" 
                            Orientation="Horizontal" 
                            VerticalAlignment="Bottom"
                            Margin="10,0,0,0">
                    <Button x:Name="SavePriceBtn" 
                            Content="💾 Сохранить" 
                            Style="{StaticResource PrimaryButtonStyle}"
                            Width="100" Height="35"
                            Click="SavePriceBtn_Click"/>
                    <Button x:Name="CancelAddBtn" 
                            Content="Отмена" 
                            Width="80" Height="35"
                            Margin="10,0,0,0"
                            Click="CancelAddBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Prices}" d:ItemsSource="{d:SampleData ItemCount=6}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border>
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource ProductCardStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Background" Value="#FFFDE7"/>
                                            <Setter Property="BorderBrush" Value="#FFD54F"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsNew}" Value="True">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                            <Setter Property="BorderBrush" Value="#81C784"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" 
                                        Width="90" Height="90"
                                        Background="White" 
                                        CornerRadius="10"
                                        Margin="0,0,15,0"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1">
                                <Image x:Name="ProductImage"
                                           Source="{Binding Product.ImagePath, Converter={StaticResource ImagePathConverter}}"
                                           Stretch="Uniform"
                                           Margin="5"/>
                            </Border>

                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Orientation="Horizontal">
                                    <TextBlock Text="{Binding Product.Name}" 
                                                   FontSize="18" FontWeight="Bold"
                                                   VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Product.Unit, StringFormat='({0})'}" 
                                                   FontSize="14" Foreground="#6C757D"
                                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Row="1" 
                                               Text="{Binding Product.ProdCategories.CategoryName}" 
                                               FontSize="12" Foreground="#6C757D"
                                               Margin="0,3,0,0"/>

                                <StackPanel Grid.Row="2" 
                                                Orientation="Horizontal" 
                                                Margin="0,10,0,0">
                                    <TextBlock Text="Цена поставщика:" 
                                                   VerticalAlignment="Center" 
                                                   FontSize="14"
                                                   Margin="0,0,10,0"/>

                                    <TextBlock x:Name="PriceText"
                                                   Text="{Binding Price.Price, StringFormat='C'}"
                                                   FontSize="20" FontWeight="Bold"
                                                   Foreground="#007BFF"
                                                   VerticalAlignment="Center"
                                                   Visibility="Visible"/>

                                    <TextBox x:Name="PriceEditBox"
                                                 Text="{Binding Price.Price, StringFormat='N2', UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource PriceTextBoxStyle}"
                                                 Visibility="Collapsed"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Column="2" 
                                            VerticalAlignment="Center"
                                            Margin="15,0,0,0">

                                <Button x:Name="EditButton"
                                            Content="✏️ Редактировать" 
                                            Height="35"
                                            Padding="10,0"
                                            Click="EditPrice_Click"
                                            Tag="{Binding}"
                                            ToolTip="Изменить цену"
                                            Visibility="Visible"/>

                                <Button x:Name="SaveButton"
                                            Content="💾 Сохранить" 
                                            Height="35"
                                            Padding="10,0"
                                            Click="SavePrice_Click"
                                            Tag="{Binding}"
                                            ToolTip="Сохранить цену"
                                            Visibility="Collapsed"
                                            Style="{StaticResource PrimaryButtonStyle}"/>

                                <Button x:Name="CancelEditButton"
                                            Content="↩ Отменить" 
                                            Height="35"
                                            Padding="10,0"
                                            Margin="0,5,0,0"
                                            Click="CancelEditPrice_Click"
                                            Tag="{Binding}"
                                            ToolTip="Отменить редактирование"
                                            Visibility="Collapsed"/>

                                <Button x:Name="DeleteButton"
                                            Content="🗑️ Удалить" 
                                            Height="35"
                                            Padding="10,0"
                                            Margin="0,10,0,0"
                                            Click="DeletePrice_Click"
                                            Tag="{Binding}"
                                            ToolTip="Удалить цену"
                                            Foreground="#DC3545">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="#FFF5F5" 
                                                        CornerRadius="5" 
                                                        BorderBrush="#FFD0D0" 
                                                        BorderThickness="1"
                                                        Padding="10,5">
                                                <ContentPresenter HorizontalAlignment="Center" 
                                                                      VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#FFE0E0"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>

                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Window>
