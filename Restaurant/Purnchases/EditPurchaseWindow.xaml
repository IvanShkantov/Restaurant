<Window x:Class="Restaurant.Purnchases.EditPurchaseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Restaurant.Purnchases"
        mc:Ignorable="d"
        Title="EditPurchaseWindow" Height="450" Width="800" Background="#F8F9FB">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="White" CornerRadius="10" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="Поставщик" Foreground="Gray"/>
                    <ComboBox ItemsSource="{Binding Suppliers}"
                          SelectedItem="{Binding SelectedSupplier}"
                          DisplayMemberPath="Name"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Дата" Foreground="Gray"/>
                    <TextBlock Text="{Binding PurchaseDate, StringFormat='dd.MM.yyyy HH:mm'}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="10" Padding="15">

            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Top" Margin="0,0,0,10">
                    <Button Content="Добавить позицию"
                    Width="170"
	            Click="AddItemButt_Click"/>

                    <TextBlock Text="{Binding EstimatedTotalPrice, StringFormat='Итого: {0:C}'}"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="20,0,0,0"
                       VerticalAlignment="Center"/>
                </StackPanel>

                <Grid DockPanel.Dock="Top" Margin="0,0,0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="50"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="40"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Продукт" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Кол-во" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="Ед." FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="Цена" FontWeight="Bold" HorizontalAlignment="Center"/>
                    <TextBlock Grid.Column="4" Text="Сумма" FontWeight="Bold" HorizontalAlignment="Center"/>
                </Grid>

                <ItemsControl ItemsSource="{Binding Items}" d:ItemsSource="{d:SampleData ItemCount=6}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>

                            <Grid Margin="0,5">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="50"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="40"/>
                                </Grid.ColumnDefinitions>

                                <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding DataContext.AvailableProducts, RelativeSource={RelativeSource AncestorType=Window}}"
                                  SelectedItem="{Binding SelectedProduct, UpdateSourceTrigger=PropertyChanged}"
                                  DisplayMemberPath="ProductName"
                                  Margin="0,0,5,0"/>

                                <TextBox Grid.Column="1"
                                 Text="{Binding Quantity, StringFormat='N2', UpdateSourceTrigger=PropertyChanged}"
                                 HorizontalContentAlignment="Center"
                                 Margin="0,0,5,0"/>

                                <TextBlock Grid.Column="2"
                                   Text="{Binding SelectedProduct.Unit}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Foreground="Gray"/>

                                <TextBlock Grid.Column="3"
                                   Text="{Binding UnitPrice, StringFormat='C'}"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>

                                <TextBlock Grid.Column="4"
                                   Text="{Binding TotalPrice, StringFormat='C'}"
                                   FontWeight="Bold"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"/>

                                <Button Grid.Column="5"
                                Content="🗑"                                
                                Click="DeleteItemButt_Click"
                                Width="30" Height="30"/>
                            </Grid>

                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </DockPanel>
        </Border>

        <StackPanel Grid.Row="2"
                Orientation="Horizontal"
                HorizontalAlignment="Right"
                Margin="0,15,0,0">

            <Button Content="Отмена"
                Width="120"
                Margin="0,0,10,0"
                Click="CancelButt_Click"/>

            <Button Content="Сохранить"
                Width="140"
                Style="{StaticResource PrimaryButtonStyle}"
                Click="SaveButt_Click"/>
        </StackPanel>

    </Grid>
</Window>
