<Page x:Class="Restaurant.Purnchases.SuppliersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restaurant.Purnchases"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SuppliersPage" Background="White">

    <Page.Resources>
        <Style x:Key="HeaderTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="#6C757D"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
        </Style>

        <Style x:Key="SupplierTextBoxStyle" TargetType="TextBox">
            <Setter Property="Padding" Value="8,5"/>
            <Setter Property="BorderBrush" Value="#CED4DA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#80BDFF"/>
                                <Setter Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DeleteButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="35"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Content" Value="🗑️"/>
            <Setter Property="ToolTip" Value="Удалить поставщика"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5"
                                Padding="3">
                            <ContentPresenter HorizontalAlignment="Center" 
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFE0E0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="ПОСТАВЩИКИ" 
                       FontSize="24" 
                       FontWeight="Bold" 
                       VerticalAlignment="Center"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="AddSupplierButt" 
                        Content="➕ Добавить поставщика" 
                        Style="{StaticResource PrimaryButtonStyle}"
                        Width="180" Height="35" 
                        Click="AddSupplierButt_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" 
                Background="#F8F9FA" 
                CornerRadius="8,8,0,0" 
                Padding="15,10"
                BorderBrush="#DEE2E6"
                BorderThickness="1,1,1,0"
                Margin="0,0,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="30"/>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                    <ColumnDefinition Width="*" MinWidth="150"/>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="#" 
                           Style="{StaticResource HeaderTextBlockStyle}"
                           HorizontalAlignment="Center"/>

                <TextBlock Grid.Column="1" Text="Название" 
                           Style="{StaticResource HeaderTextBlockStyle}"
                           Margin="10,0,0,0"/>

                <TextBlock Grid.Column="2" Text="Телефон" 
                           Style="{StaticResource HeaderTextBlockStyle}"
                           Margin="10,0,0,0"/>

                <TextBlock Grid.Column="3" Text="Email" 
                           Style="{StaticResource HeaderTextBlockStyle}"
                           Margin="10,0,0,0"/>

                <TextBlock Grid.Column="4" Text="" />
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="SuppliersItemsControl" ItemsSource="{Binding Suppliers}" d:ItemsSource="{d:SampleData ItemCount=6}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="#DEE2E6"
                                BorderThickness="1,0,1,1"
                                Padding="10">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter Property="Background" Value="#FFFDE7"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsNew}" Value="True">
                                            <Setter Property="Background" Value="#E8F5E9"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="30"/>
                                    <ColumnDefinition Width="*" MinWidth="200"/>
                                    <ColumnDefinition Width="*" MinWidth="150"/>
                                    <ColumnDefinition Width="*" MinWidth="200"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0" VerticalAlignment="Center">
                                    <TextBlock x:Name="IndexText"
                                               Text="{Binding Index}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               Foreground="#6C757D"
                                               FontWeight="Bold"
                                               Visibility="Visible"/>
                                </Grid>

                                <Grid Grid.Column="1" Margin="5,0">
                                    <TextBlock x:Name="NameText"
                                               Text="{Binding Supplier.Name}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Visibility="Visible"/>

                                    <TextBox x:Name="NameBox"
                                             Text="{Binding Supplier.Name, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SupplierTextBoxStyle}"
                                             Visibility="Collapsed"
                                             Tag="Название"/>
                                </Grid>

                                <Grid Grid.Column="2" Margin="5,0">
                                    <TextBlock x:Name="PhoneText"
                                               Text="{Binding Supplier.Phone, TargetNullValue='—'}"
                                               VerticalAlignment="Center"
                                               Visibility="Visible"/>

                                    <TextBox x:Name="PhoneBox"
                                             Text="{Binding Supplier.Phone, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SupplierTextBoxStyle}"
                                             Visibility="Collapsed"
                                             Tag="Телефон"/>
                                </Grid>

                                <Grid Grid.Column="3" Margin="5,0">
                                    <TextBlock x:Name="EmailText"
                                               Text="{Binding Supplier.Email, TargetNullValue='—'}"
                                               VerticalAlignment="Center"
                                               Visibility="Visible"/>

                                    <TextBox x:Name="EmailBox"
                                             Text="{Binding Supplier.Email, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource SupplierTextBoxStyle}"
                                             Visibility="Collapsed"
                                             Tag="Email"/>
                                </Grid>

                                <StackPanel Grid.Column="4" 
                                            Orientation="Horizontal" 
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Right">

                                    <Button x:Name="EditButton"
                                            Content="✏️" 
                                            Width="25" Height="25"
                                            Click="EditSupplier_Click"
                                            Tag="{Binding}"
                                            ToolTip="Редактировать"
                                            Style="{StaticResource IconButtonStyle}"/>

                                    <Button x:Name="SaveButton"
                                            Content="💾" 
                                            Width="25" Height="25"
                                            Click="SaveSupplier_Click"
                                            Tag="{Binding}"
                                            ToolTip="Сохранить"
                                            Visibility="Collapsed"
                                            Style="{StaticResource IconButtonStyle}"/>

                                    <Button x:Name="CancelButton"
                                            Content="↩" 
                                            Width="25" Height="25"
                                            Click="CancelEdit_Click"
                                            Tag="{Binding}"
                                            ToolTip="Отменить"
                                            Visibility="Collapsed"
                                            Style="{StaticResource IconButtonStyle}"/>

                                    <Button x:Name="DeleteButton"
                                            Style="{StaticResource DeleteButtonStyle}"
                                            Click="DeleteSupplier_Click"
                                            Tag="{Binding}"/>
                                    
                                    <Button Content="💰" 
                                            Width="25" Height="25"
                                            Click="OpenPrices_Click"
                                            Tag="{Binding}"
                                            ToolTip="Цены поставщика"
                                            Style="{StaticResource IconButtonStyle}"/>          
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Button Content="⬅️ Назад" Grid.Row="3" 
Width="100" Height="38"
Click="Back_Click"
Style="{StaticResource SecondaryButtonStyle}"
VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
    </Grid>
</Page>
