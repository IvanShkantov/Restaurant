<Page x:Class="Restaurant.Purnchases.SuppliersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Restaurant.Purnchases"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="600.626"
      Title="SuppliersPage" Background="#F8FAFC">

    <Page.Resources>
        <DropShadowEffect x:Key="HeaderShadow" BlurRadius="20" ShadowDepth="0" Opacity="0.05"/>
        <DropShadowEffect x:Key="TableShadow" BlurRadius="12" ShadowDepth="2" Opacity="0.06"/>
    </Page.Resources>

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,22" Background="White" CornerRadius="16" Padding="20" Effect="{StaticResource HeaderShadow}">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Поставщики" FontSize="28" FontWeight="Bold" 
                               Foreground="#1E293B" VerticalAlignment="Center"/>
                </StackPanel>
                <Button x:Name="AddSupplierButt" 
                        Content="➕  Добавить поставщика"
                        Height="42" Padding="20,0"
                        HorizontalAlignment="Right"
                        Click="AddSupplierButt_Click"
                        Background="#3B82F6"
                        Foreground="White"
                        BorderThickness="0"
                        FontWeight="SemiBold"
                        FontSize="14"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="12"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="White" CornerRadius="14" Effect="{StaticResource TableShadow}" Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F8FAFC" CornerRadius="14,14,0,0" Padding="18,14" Margin="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="50"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="160"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="№" 
                                   Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="НАЗВАНИЕ" 
                                   Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="8,0"/>
                        <TextBlock Grid.Column="2" Text="ТЕЛЕФОН" 
                                   Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="8,0"/>
                        <TextBlock Grid.Column="3" Text="EMAIL" 
                                   Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" Margin="8,0"/>
                        <TextBlock Grid.Column="4" Text="ДЕЙСТВИЯ" 
                                   Foreground="#94A3B8" FontWeight="SemiBold" FontSize="12" HorizontalAlignment="Center"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="SuppliersItemsControl" ItemsSource="{Binding Suppliers}" d:ItemsSource="{d:SampleData ItemCount=6}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#F1F5F9" BorderThickness="0,0,0,1" Padding="14,12">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                    <Setter Property="Background" Value="#FFFBEB"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsNew}" Value="True">
                                                    <Setter Property="Background" Value="#F0FDF4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="160"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Index}"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"
                                                   Foreground="#94A3B8"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"/>

                                        <Grid Grid.Column="1" Margin="4,0">
                                            <TextBlock x:Name="NameText"
                                                           Text="{Binding Supplier.Name}"
                                                           VerticalAlignment="Center"
                                                           FontWeight="SemiBold"
                                                           FontSize="14"
                                                           Foreground="#1E293B"
                                                           Visibility="Visible"/>
                                            <TextBox x:Name="NameBox"
                                                         Text="{Binding Supplier.Name, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14" Padding="10,8"
                                                         FontWeight="Medium"
                                                         Background="White"
                                                         BorderBrush="#E2E8F0"
                                                         BorderThickness="1"
                                                         Visibility="Collapsed">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </Grid>

                                        <Grid Grid.Column="2" Margin="4,0">
                                            <TextBlock x:Name="PhoneText"
                                                           Text="{Binding Supplier.Phone, TargetNullValue='—'}"
                                                           VerticalAlignment="Center"
                                                           FontSize="14"
                                                           Foreground="#475569"
                                                           Visibility="Visible"/>
                                            <TextBox x:Name="PhoneBox"
                                                         Text="{Binding Supplier.Phone, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14" Padding="10,8"
                                                         FontWeight="Medium"
                                                         Background="White"
                                                         BorderBrush="#E2E8F0"
                                                         BorderThickness="1"
                                                         Visibility="Collapsed">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </Grid>

                                        <Grid Grid.Column="3" Margin="4,0">
                                            <TextBlock x:Name="EmailText"
                                                           Text="{Binding Supplier.Email, TargetNullValue='—'}"
                                                           VerticalAlignment="Center"
                                                           FontSize="14"
                                                           Foreground="#475569"
                                                           Visibility="Visible"/>
                                            <TextBox x:Name="EmailBox"
                                                         Text="{Binding Supplier.Email, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="14" Padding="10,8"
                                                         FontWeight="Medium"
                                                         Background="White"
                                                         BorderBrush="#E2E8F0"
                                                         BorderThickness="1"
                                                         Visibility="Collapsed">
                                                <TextBox.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </TextBox.Resources>
                                            </TextBox>
                                        </Grid>

                                        <StackPanel Grid.Column="4" 
                                                    Orientation="Horizontal" 
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center">
                                            <Button x:Name="EditButton"
                                                    Content="✏️"
                                                    Width="34" Height="34"
                                                    Click="EditSupplier_Click"
                                                    Tag="{Binding}"
                                                    ToolTip="Редактировать"
                                                    Background="#EFF6FF"
                                                    Foreground="#3B82F6"
                                                    BorderThickness="0"
                                                    FontSize="14"
                                                    Cursor="Hand">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button x:Name="SaveButton"
                                                    Content="💾"
                                                    Width="34" Height="34"
                                                    Margin="3,0,0,0"
                                                    Click="SaveSupplier_Click"
                                                    Tag="{Binding}"
                                                    ToolTip="Сохранить"
                                                    Visibility="Collapsed"
                                                    Background="#ECFDF5"
                                                    Foreground="#10B981"
                                                    BorderThickness="0"
                                                    FontSize="14"
                                                    Cursor="Hand">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button x:Name="CancelButton"
                                                    Content="↩"
                                                    Width="34" Height="34"
                                                    Margin="3,0,0,0"
                                                    Click="CancelEdit_Click"
                                                    Tag="{Binding}"
                                                    ToolTip="Отменить"
                                                    Visibility="Collapsed"
                                                    Background="#F1F5F9"
                                                    Foreground="#64748B"
                                                    BorderThickness="0"
                                                    FontSize="14"
                                                    Cursor="Hand">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button x:Name="DeleteButton"
                                                    Content="🗑"
                                                    Width="34" Height="34"
                                                    Margin="3,0,0,0"
                                                    Click="DeleteSupplier_Click"
                                                    Tag="{Binding}"
                                                    ToolTip="Удалить поставщика"
                                                    Background="#FEE2E2"
                                                    Foreground="#EF4444"
                                                    BorderThickness="0"
                                                    FontSize="14"
                                                    Cursor="Hand">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>

                                            <Button Content="💰"
                                                    Width="34" Height="34"
                                                    Margin="3,0,0,0"
                                                    Click="OpenPrices_Click"
                                                    Tag="{Binding}"
                                                    ToolTip="Цены поставщика"
                                                    Background="#FEF3C7"
                                                    Foreground="#D97706"
                                                    BorderThickness="0"
                                                    FontSize="14"
                                                    Cursor="Hand">
                                                <Button.Resources>
                                                    <Style TargetType="Border">
                                                        <Setter Property="CornerRadius" Value="8"/>
                                                    </Style>
                                                </Button.Resources>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="2" Padding="0" Margin="0,18,0,0">
            <Button Content="←  Назад"
                    Height="40" Width="110"
                    HorizontalAlignment="Right"
                    Click="Back_Click"
                    Background="White"
                    Foreground="#64748B"
                    BorderBrush="#E2E8F0"
                    BorderThickness="1"
                    FontWeight="SemiBold"
                    Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="10"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Border>
    </Grid>
</Page>